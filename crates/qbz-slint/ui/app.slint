// QBZ Slint MVP — UI entry point.
//
// Stays thin: imports the feature screens and exports the single
// top-level window. No raw visual constants or domain logic here
// (MVP ADR, sections 13 and 21).

import { Theme } from "foundation/semantic-colors.slint";
import { SplashScreen } from "splash/SplashScreen.slint";
import { LoginScreen } from "login/LoginScreen.slint";
import { AppShell } from "shell/AppShell.slint";

// Re-export the state globals so the Rust layer can populate them.
export { HomeState, AlbumState, NavState, SessionState } from "state.slint";

// Which top-level screen is shown. The app starts on `splash` while it
// restores a saved session, then resolves to `shell` or `login`.
export enum AppScreen { splash, login, shell }

export component AppWindow inherits Window {
    title: "QBZ";
    preferred-width: 1180px;
    preferred-height: 760px;
    min-width: 940px;
    min-height: 600px;
    background: Theme.surface-main;

    in-out property <AppScreen> screen: AppScreen.splash;

    // Forwarded to the Rust layer.
    callback sign-in-via-browser();
    callback use-system-browser();
    callback start-offline();
    callback open-tos();
    callback open-album(string);
    callback logout();
    callback close-app();

    if root.screen == AppScreen.splash: SplashScreen { }

    if root.screen == AppScreen.login: LoginScreen {
        sign-in-via-browser => {
            root.sign-in-via-browser();
        }
        use-system-browser => {
            root.use-system-browser();
        }
        start-offline => {
            root.start-offline();
        }
        open-tos => {
            root.open-tos();
        }
    }

    if root.screen == AppScreen.shell: AppShell {
        open-album(id) => {
            root.open-album(id);
        }
        logout => {
            root.logout();
        }
        close-app => {
            root.close-app();
        }
    }
}
