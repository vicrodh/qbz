// Left navigation sidebar — the playlists list.
//
// The playlist list is empty until real playlist data is wired (the
// sidebar is a later milestone). The user element now lives in the
// header, not at the bottom of the sidebar.
//
// The sidebar is collapsible: its rendered width is driven by
// ShellState (0px when collapsed, otherwise the user-set width). A thin
// drag handle on the right edge resizes it, clamped to [200px, 420px];
// dragging below ~160px collapses it entirely.

import { Theme } from "../foundation/semantic-colors.slint";
import { Spacing } from "../foundation/spacing.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";
import { ShellState, SidebarState, SidebarActions, SidebarPlaylistItem } from "../state.slint";
import { ScrollView } from "std-widgets.slint";

// One playlist row in the sidebar.
component PlaylistRow inherits Rectangle {
    in property <SidebarPlaylistItem> item;
    in property <bool> active: false;
    callback clicked(string);

    height: 32px;
    border-radius: 6px;
    background: ta.has-hover || root.active ? Theme.surface-hover : transparent;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 8px;
        VerticalLayout {
            alignment: center;
            QbzIcon {
                source: @image-url("../assets/icons/list-music.svg");
                width: 15px;
                height: 15px;
                tint: root.active ? Theme.text-primary : Theme.text-muted;
            }
        }
        Text {
            text: root.item.name;
            color: root.active ? Theme.text-primary : Theme.text-secondary;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked(root.item.id);
        }
    }
}

export component Sidebar inherits Rectangle {
    // Rendered width — 0 when collapsed, otherwise the user-set width.
    width: ShellState.sidebar-collapsed ? 0px : ShellState.sidebar-width;
    // The sidebar sits one surface above the content area, matching the
    // QBZ dark theme (--bg-secondary sidebar over --bg-primary content).
    background: Theme.surface-card;
    // Clip so content doesn't spill while the width animates to 0.
    clip: true;
    animate width { duration: 160ms; easing: ease-in-out; }

    // Captured sidebar width at pointer-down, so drag deltas are
    // measured from a stable origin.
    property <length> drag-start-width: ShellState.sidebar-width;

    VerticalLayout {
        padding: Spacing.md;
        spacing: Spacing.md;

        HorizontalLayout {
            Text {
                text: @tr("PLAYLISTS");
                color: Theme.text-muted;
                font-size: 11px;
                letter-spacing: 1.5px;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 4px;
                    background: plus-ta.has-hover ? Theme.surface-hover : transparent;
                    QbzIcon {
                        source: @image-url("../assets/icons/plus.svg");
                        width: 16px;
                        height: 16px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        tint: plus-ta.has-hover ? Theme.text-primary : Theme.text-muted;
                    }
                    plus-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            SidebarActions.create-playlist();
                        }
                    }
                }
            }
        }

        ScrollView {
            vertical-stretch: 1;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            VerticalLayout {
                spacing: 2px;
                alignment: start;
                for pl in SidebarState.playlists: PlaylistRow {
                    item: pl;
                    active: pl.id == SidebarState.active-id;
                    clicked(id) => {
                        SidebarActions.open-playlist(id);
                    }
                }
                if SidebarState.playlists.length == 0 && !SidebarState.loading: Text {
                    text: @tr("No playlists yet.");
                    color: Theme.text-muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
    }

    // Drag handle — a thin strip pinned to the right edge. Resizes the
    // sidebar; below ~160px it collapses instead of resizing.
    drag-handle := TouchArea {
        x: parent.width - self.width;
        width: 6px;
        height: parent.height;
        mouse-cursor: ew-resize;

        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                root.drag-start-width = ShellState.sidebar-width;
            }
        }
        moved => {
            if (self.pressed) {
                if (root.drag-start-width + (self.mouse-x - self.pressed-x) < 160px) {
                    ShellState.sidebar-collapsed = true;
                } else {
                    ShellState.sidebar-width = Math.min(Math.max(
                        root.drag-start-width + (self.mouse-x - self.pressed-x),
                        200px), 420px);
                }
            }
        }
    }
}
