// App shell — the post-login frame: header bar, sidebar, content
// region, and player bar.
//
// The content region is a placeholder; the Discover / Home view lands
// in the next increment. Hairlines separate the regions.

import { Theme } from "../foundation/semantic-colors.slint";
import { Layout } from "../foundation/layout.slint";
import { Sidebar } from "Sidebar.slint";
import { HeaderBar } from "HeaderBar.slint";
import { PlayerBar } from "PlayerBar.slint";
import { HomeView } from "../discover/HomeView.slint";

export component AppShell inherits Rectangle {
    background: Theme.surface-main;

    VerticalLayout {
        spacing: 0px;

        HeaderBar { }
        Rectangle {
            height: Layout.hairline;
            background: Theme.border-subtle;
        }

        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0px;

            Sidebar { }
            Rectangle {
                width: Layout.hairline;
                background: Theme.border-subtle;
            }
            HomeView {
                horizontal-stretch: 1;
            }
        }

        Rectangle {
            height: Layout.hairline;
            background: Theme.border-subtle;
        }
        PlayerBar { }
    }
}
