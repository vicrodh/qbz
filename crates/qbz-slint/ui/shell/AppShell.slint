// App shell — the post-login frame: header bar, sidebar, content
// region, and player bar. The content region shows either the Discover
// Home view or the Album detail view, driven by NavState.

import { Theme } from "../foundation/semantic-colors.slint";
import { Layout } from "../foundation/layout.slint";
import { NavState } from "../state.slint";
import { Sidebar } from "Sidebar.slint";
import { HeaderBar } from "HeaderBar.slint";
import { PlayerBar } from "PlayerBar.slint";
import { HomeView } from "../discover/HomeView.slint";
import { AlbumPageView } from "../album/AlbumPageView.slint";

export component AppShell inherits Rectangle {
    callback open-album(string);
    callback logout();
    callback close-app();

    background: Theme.surface-main;

    VerticalLayout {
        spacing: 0px;

        HeaderBar {
            logout => {
                root.logout();
            }
            close-app => {
                root.close-app();
            }
        }
        Rectangle {
            height: Layout.hairline;
            background: Theme.border-subtle;
        }

        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0px;

            Sidebar { }
            Rectangle {
                width: Layout.hairline;
                background: Theme.border-subtle;
            }

            // Content region — Home or Album detail.
            Rectangle {
                horizontal-stretch: 1;
                background: Theme.surface-main;

                if !NavState.showing-album: HomeView {
                    album-clicked(id) => {
                        root.open-album(id);
                    }
                }
                if NavState.showing-album: AlbumPageView { }
            }
        }

        Rectangle {
            height: Layout.hairline;
            background: Theme.border-subtle;
        }
        PlayerBar { }
    }
}
