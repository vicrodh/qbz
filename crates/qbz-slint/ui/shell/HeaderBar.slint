// Top header bar — three equal sections: navigation tabs (left), the
// search field (center, so it lands at the window center), and the user
// element with its dropdown menu (right).
//
// Responsive: below the first breakpoint the tabs drop their icons;
// below the second the search field narrows to 70%.

import { Theme } from "../foundation/semantic-colors.slint";
import { Spacing } from "../foundation/spacing.slint";
import { Typography } from "../foundation/typography.slint";
import { Layout } from "../foundation/layout.slint";
import { Radius } from "../foundation/radius.slint";
import { SessionState } from "../state.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";

component NavTab inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> active: false;
    in property <bool> show-icon: true;
    callback clicked();

    height: 30px;
    border-radius: Radius.sm;
    background: root.active ? Theme.surface-elevated
        : ta.has-hover ? Theme.surface-hover : transparent;

    HorizontalLayout {
        padding-left: root.show-icon ? 9px : 11px;
        padding-right: 11px;
        spacing: 6px;
        if root.show-icon: VerticalLayout {
            alignment: center;
            QbzIcon {
                source: root.icon;
                width: 14px;
                height: 14px;
                tint: root.active ? Theme.text-primary : Theme.text-secondary;
            }
        }
        Text {
            text: root.label;
            color: root.active ? Theme.text-primary : Theme.text-secondary;
            font-size: 12px;
            font-weight: root.active ? Typography.semibold : Typography.regular;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

component MenuItem inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    callback clicked();

    height: 34px;
    background: ta.has-hover ? Theme.surface-hover : transparent;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 18px;
        spacing: 10px;
        VerticalLayout {
            alignment: center;
            QbzIcon {
                source: root.icon;
                width: 15px;
                height: 15px;
                tint: Theme.text-secondary;
            }
        }
        Text {
            text: root.label;
            color: Theme.text-secondary;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component HeaderBar inherits Rectangle {
    callback logout();
    callback close-app();

    height: Layout.header-height;
    background: Theme.surface-card;

    // Responsive breakpoints.
    property <bool> show-tab-icons: root.width >= 1140px;
    property <length> search-width: root.width < 960px ? 224px : 320px;

    HorizontalLayout {
        // --- Tabs (left third) -------------------------------------------
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            HorizontalLayout {
                padding-left: Spacing.md;
                spacing: Spacing.xs;
                alignment: start;
                NavTab {
                    icon: @image-url("../assets/icons/compass.svg");
                    label: "Discover";
                    active: true;
                    show-icon: root.show-tab-icons;
                }
                NavTab {
                    icon: @image-url("../assets/icons/library-big.svg");
                    label: "Library";
                    show-icon: root.show-tab-icons;
                }
                NavTab {
                    icon: @image-url("../assets/icons/hard-drive.svg");
                    label: "Local Library";
                    show-icon: root.show-tab-icons;
                }
                NavTab {
                    icon: @image-url("../assets/icons/cassette-tape.svg");
                    label: "My QBZ";
                    show-icon: root.show-tab-icons;
                }
            }
        }

        // --- Search (center third) ---------------------------------------
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: root.search-width;
                    height: 32px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    background: Theme.surface-elevated;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 7px;
                        VerticalLayout {
                            alignment: center;
                            QbzIcon {
                                source: @image-url("../assets/icons/search.svg");
                                width: 14px;
                                height: 14px;
                                tint: Theme.text-muted;
                            }
                        }
                        Text {
                            text: @tr("Search");
                            color: Theme.text-muted;
                            font-size: 13px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                }
            }
        }

        // --- User element (right third) ----------------------------------
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            HorizontalLayout {
                padding-right: Spacing.md;
                alignment: end;
                user-area := TouchArea {
                    width: user-row.preferred-width + 16px;
                    height: 36px;
                    mouse-cursor: pointer;
                    clicked => {
                        menu.show();
                    }
                    Rectangle {
                        width: 100%;
                        height: 100%;
                        border-radius: Radius.sm;
                        background: user-area.has-hover ? Theme.surface-hover : transparent;
                    }
                    user-row := HorizontalLayout {
                        x: 8px;
                        height: parent.height;
                        spacing: 9px;
                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: SessionState.user-name == ""
                                    ? @tr("Guest")
                                    : SessionState.user-name;
                                color: Theme.text-primary;
                                font-size: Typography.body;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            QbzIcon {
                                source: @image-url("../assets/icons/menu.svg");
                                width: 18px;
                                height: 18px;
                                tint: Theme.text-secondary;
                            }
                        }
                    }
                }
            }
        }
    }

    menu := PopupWindow {
        x: parent.width - 234px - Spacing.md;
        y: Layout.header-height - 4px;
        width: 234px;
        height: 254px;

        Rectangle {
            background: Theme.surface-elevated;
            border-radius: Radius.md;
            border-width: 1px;
            border-color: Theme.border-subtle;
            drop-shadow-blur: 24px;
            drop-shadow-color: Theme.card-shadow;
            drop-shadow-offset-y: 6px;

            VerticalLayout {
                padding-top: 6px;
                padding-bottom: 6px;
                MenuItem {
                    icon: @image-url("../assets/icons/settings.svg");
                    label: @tr("Settings");
                }
                MenuItem {
                    icon: @image-url("../assets/icons/keyboard.svg");
                    label: @tr("Keyboard Shortcuts");
                }
                MenuItem {
                    icon: @image-url("../assets/icons/book-open.svg");
                    label: @tr("Documentation");
                }
                MenuItem {
                    icon: @image-url("../assets/icons/bug.svg");
                    label: @tr("Report an Issue");
                }
                MenuItem {
                    icon: @image-url("../assets/icons/info.svg");
                    label: @tr("About");
                }
                Rectangle {
                    height: 1px;
                    background: Theme.border-subtle;
                }
                MenuItem {
                    icon: @image-url("../assets/icons/log-out.svg");
                    label: @tr("Log Out");
                    clicked => {
                        root.logout();
                    }
                }
                MenuItem {
                    icon: @image-url("../assets/icons/x.svg");
                    label: @tr("Close");
                    clicked => {
                        root.close-app();
                    }
                }
            }
        }
    }
}
