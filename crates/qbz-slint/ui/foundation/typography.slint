// Typography scale — font sizes and weights.

export global Typography {
    out property <length> legal: 13px;
    out property <length> link: 14px;
    out property <length> body: 15px;
    out property <length> subtitle: 15px;
    out property <length> button: 17px;
    // Canonical page / section title — Home section headings ("New
    // Releases", ...) and the hero titles on Album / Artist / Playlist
    // / Mixtape detail pages. One size for all, for consistency.
    out property <length> section: 18px;
    out property <length> heading: 19px;
    out property <length> title: 25px;
    out property <length> wordmark: 29px;

    out property <int> regular: 400;
    out property <int> medium: 500;
    out property <int> semibold: 600;
    out property <int> bold: 700;
}
