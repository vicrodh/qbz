// A track result row for search.
//
// Like the album-page track row, but the leading slot is a cover
// thumbnail — search tracks come from many different albums, so a shared
// album cover would be wrong. `show-artwork` keeps the slot configurable
// for a future shared row component (album context would set it false).

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { SearchTrackItem } from "../state.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";
import { TrackPlayCell } from "../primitives/TrackPlayCell.slint";
import { TrackContextMenu } from "../primitives/TrackContextMenu.slint";

export component SearchTrackRow inherits Rectangle {
    in property <SearchTrackItem> track;
    in property <int> index;
    in property <bool> show-artwork: true;
    // kind ("track"), track id, action ("play" | "play-next" | "queue" | "favorite").
    callback media-action(string, string, string);

    // Slint's has-hover does not propagate to ancestor TouchAreas, so the
    // row OR's its own ta with every nested TouchArea to drive the cell
    // play overlay reliably regardless of pointer position.
    property <bool> row-hovered:
        ta.has-hover || play-cell.hovered || more-ta.has-hover;

    height: 56px;
    border-radius: 8px;
    background: ta.has-hover
        ? #ffffff16
        : (Math.mod(root.index, 2) == 1 ? #ffffff07 : transparent);

    ta := TouchArea {
        mouse-cursor: default;
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 14px;

        // Track position in the result list.
        Text {
            text: "\{root.index + 1}";
            width: 24px;
            color: Theme.text-muted;
            font-size: Typography.body;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        // Leading slot — cover thumbnail with the play / playing-state
        // affordance.
        VerticalLayout {
            alignment: center;
            play-cell := TrackPlayCell {
                track-id: root.track.id;
                artwork: root.track.artwork;
                show-artwork: true;
                row-hovered: root.row-hovered;
                play => {
                    root.media-action("track", root.track.id, "play");
                }
            }
        }

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;
            HorizontalLayout {
                alignment: start;
                spacing: 6px;
                Text {
                    text: root.track.title;
                    color: Theme.text-primary;
                    font-size: Typography.body;
                    font-weight: Typography.medium;
                    vertical-alignment: center;
                    overflow: elide;
                }
                if root.track.explicit: VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 16px;
                        height: 16px;
                        border-radius: 3px;
                        background: Theme.surface-elevated;
                        Text {
                            text: "E";
                            color: Theme.text-muted;
                            font-size: 9px;
                            font-weight: Typography.semibold;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
            Text {
                text: root.track.artist;
                visible: root.track.artist != "";
                color: Theme.text-muted;
                font-size: Typography.link;
                overflow: elide;
            }
        }

        Text {
            text: root.track.duration;
            width: 70px;
            color: Theme.text-muted;
            font-size: Typography.body;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        Text {
            text: root.track.quality-tier == "hires"
                ? "Hi-Res"
                : (root.track.quality-tier == "cd" ? "CD" : "");
            width: 60px;
            color: Theme.text-muted;
            font-size: Typography.legal;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: Radius.sm;
                background: more-ta.has-hover ? Theme.surface-elevated : transparent;
                QbzIcon {
                    source: @image-url("../assets/icons/ellipsis.svg");
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: more-ta.has-hover ? Theme.text-primary : Theme.text-muted;
                }
                more-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        track-menu.show();
                    }
                }
            }
        }
    }

    track-menu := TrackContextMenu {
        x: parent.width - self.width - 12px;
        y: 48px;
        track-id: root.track.id;
        media-action(k, i, a) => {
            root.media-action(k, i, a);
        }
    }
}
