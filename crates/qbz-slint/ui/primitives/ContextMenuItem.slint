// One row of a context menu — an icon, a label, and a click callback.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { QbzIcon } from "QbzIcon.slint";

export component ContextMenuItem inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    // When false the row collapses to zero height and stops rendering /
    // capturing input — lets a `for` build a filtered list without an
    // inner `if` (which Slint does not allow as a direct `for` child).
    in property <bool> shown: true;
    // When false the row is muted and ignores clicks (a feature that exists
    // but is not available yet, e.g. Mini / Immersive window modes).
    in property <bool> enabled: true;
    // Optional trailing check, for single-choice menus (the selected row).
    in property <bool> selected: false;
    // Destructive action (Remove from playlist / Remove offline copy) —
    // red icon + label, mirroring Tauri's TrackMenu danger rows. Same red
    // as the MultiSelectBar danger button.
    in property <bool> danger: false;
    callback clicked();

    height: root.shown ? 33px : 0px;
    visible: root.shown;
    clip: true;
    background: (ta.has-hover && root.enabled) ? Theme.surface-hover : transparent;
    opacity: root.enabled ? 1.0 : 0.4;

    HorizontalLayout {
        padding-left: 11px;
        padding-right: 16px;
        spacing: 10px;
        VerticalLayout {
            alignment: center;
            QbzIcon {
                source: root.icon;
                width: 15px;
                height: 15px;
                tint: root.danger
                    ? #ef4444
                    : (ta.has-hover ? Theme.text-primary : Theme.text-secondary);
            }
        }
        Text {
            text: root.label;
            color: root.danger
                ? #ef4444
                : (ta.has-hover ? Theme.text-primary : Theme.text-secondary);
            font-size: 13px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        if root.selected: VerticalLayout {
            alignment: center;
            QbzIcon {
                source: @image-url("../assets/icons/check.svg");
                width: 14px;
                height: 14px;
                tint: Theme.accent;
            }
        }
    }

    ta := TouchArea {
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }
    }
}
