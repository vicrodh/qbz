// Local-album tag editor modal. Album + per-track fields, sidecar (default)
// or opt-in direct file-write. Mounted last in AppShell so it overlays all
// chrome (ADR-009). Remote MusicBrainz/Discogs lookup is a follow-up sub-slice.
//
// Driven by TagEditorState / TagEditorActions. visible:-gated (ADR-010 modal
// pattern, like EditPlaylistModal). ADR-008: persistence picker is a QbzSelect,
// no pills.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { TagEditorState, TagEditorActions } from "../state.slint";
import { QbzIcon } from "QbzIcon.slint";
import { QbzSelect } from "QbzSelect.slint";
import { LoadingSpinner } from "LoadingSpinner.slint";
import { LineEdit, ScrollView } from "std-widgets.slint";

// A labeled field block (label above the control).
component Field inherits VerticalLayout {
    in property <string> label;
    spacing: 5px;
    Text {
        text: root.label;
        color: Theme.text-muted;
        font-size: Typography.legal;
        font-weight: Typography.semibold;
    }
    @children
}

export component TagEditorModal inherits Rectangle {
    visible: TagEditorState.open;

    if TagEditorState.open: Rectangle {
        background: #000000bf;
        TouchArea {
            mouse-cursor: default;
            clicked => {
                if (!TagEditorState.saving) {
                    TagEditorActions.close();
                }
            }
        }
        Rectangle {
            width: Math.min(root.width - 80px, 820px);
            height: Math.min(root.height - 80px, 720px);
            x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
            y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
            border-radius: Radius.md;
            background: Theme.surface-card;
            border-width: 1px;
            border-color: Theme.border-subtle;
            drop-shadow-blur: 32px;
            drop-shadow-color: #00000080;
            TouchArea { }

            VerticalLayout {
                padding: 22px;
                spacing: 14px;

                // Header.
                HorizontalLayout {
                    Text {
                        text: @tr("Edit metadata");
                        color: Theme.text-primary;
                        font-size: Typography.heading;
                        font-weight: Typography.semibold;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    close-x := TouchArea {
                        width: 28px;
                        height: 28px;
                        mouse-cursor: pointer;
                        clicked => {
                            if (!TagEditorState.saving) {
                                TagEditorActions.close();
                            }
                        }
                        QbzIcon {
                            source: @image-url("../assets/icons/x.svg");
                            width: 17px;
                            height: 17px;
                            x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                            y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                            tint: close-x.has-hover ? Theme.text-primary : Theme.text-muted;
                        }
                    }
                }

                // Album title + artist.
                HorizontalLayout {
                    spacing: 12px;
                    Field {
                        label: @tr("Album title");
                        horizontal-stretch: 1;
                        LineEdit {
                            placeholder-text: @tr("Album title");
                            text <=> TagEditorState.album_title;
                        }
                    }
                    Field {
                        label: @tr("Album artist");
                        horizontal-stretch: 1;
                        LineEdit {
                            placeholder-text: @tr("Album artist");
                            text <=> TagEditorState.album_artist;
                        }
                    }
                }

                // Year / Genre / Catalog.
                HorizontalLayout {
                    spacing: 12px;
                    Field {
                        label: @tr("Year");
                        width: 120px;
                        LineEdit {
                            placeholder-text: "—";
                            text <=> TagEditorState.year_input;
                        }
                    }
                    Field {
                        label: @tr("Genre");
                        horizontal-stretch: 1;
                        LineEdit {
                            placeholder-text: @tr("Genre");
                            text <=> TagEditorState.genre;
                        }
                    }
                    Field {
                        label: @tr("Catalog number");
                        horizontal-stretch: 1;
                        LineEdit {
                            placeholder-text: "—";
                            text <=> TagEditorState.catalog_number;
                        }
                    }
                }

                // Total discs (collected, not persisted — rendered once).
                Text {
                    text: @tr("Total discs") + ": \{TagEditorState.album_total_discs}";
                    color: Theme.text-muted;
                    font-size: Typography.legal;
                }

                // Remote metadata lookup (MusicBrainz / Discogs).
                Rectangle {
                    border-radius: Radius.sm;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    background: Theme.surface-elevated;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 8px;
                        // Provider + search.
                        HorizontalLayout {
                            spacing: 8px;
                            VerticalLayout {
                                alignment: center;
                                QbzSelect {
                                    menu-width: 150px;
                                    sm: true;
                                    options: ["MusicBrainz", "Discogs"];
                                    current-index: TagEditorState.remote_provider_index;
                                    selected(i) => {
                                        TagEditorActions.set-provider(i);
                                    }
                                }
                            }
                            Rectangle {
                                width: search-row.preferred-width + 26px;
                                height: 32px;
                                border-radius: Radius.sm;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                background: search-ta.has-hover ? Theme.surface-hover : Theme.surface-card;
                                search-row := HorizontalLayout {
                                    padding-left: 13px;
                                    padding-right: 13px;
                                    spacing: 6px;
                                    if TagEditorState.remote_searching: VerticalLayout {
                                        alignment: center;
                                        LoadingSpinner { size: 14px; }
                                    }
                                    if !TagEditorState.remote_searching: VerticalLayout {
                                        alignment: center;
                                        QbzIcon {
                                            source: @image-url("../assets/icons/search.svg");
                                            width: 14px;
                                            height: 14px;
                                            tint: Theme.text-secondary;
                                        }
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: TagEditorState.remote_searching ? @tr("Searching…") : @tr("Search");
                                            color: Theme.text-secondary;
                                            font-size: Typography.legal;
                                            font-weight: Typography.medium;
                                        }
                                    }
                                }
                                search-ta := TouchArea {
                                    mouse-cursor: TagEditorState.remote_searching ? default : pointer;
                                    clicked => {
                                        if (!TagEditorState.remote_searching) {
                                            TagEditorActions.search-remote();
                                        }
                                    }
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }

                        // No-results note.
                        if TagEditorState.has_searched && !TagEditorState.remote_searching
                            && TagEditorState.remote_results.length == 0: Text {
                            text: @tr("No results, try a different search");
                            color: Theme.text-muted;
                            font-size: Typography.legal;
                        }

                        // Results — horizontal scroll of selectable cards.
                        if TagEditorState.show_remote_panel
                            && TagEditorState.remote_results.length > 0: Rectangle {
                            height: 116px;
                            ScrollView {
                                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                                HorizontalLayout {
                                    spacing: 8px;
                                    padding-bottom: 6px;
                                    for r in TagEditorState.remote_results: Rectangle {
                                        width: 200px;
                                        border-radius: Radius.sm;
                                        border-width: 1px;
                                        property <bool> sel: r.provider_id == TagEditorState.selected_result_id;
                                        border-color: self.sel ? Theme.accent : Theme.border-subtle;
                                        background: self.sel ? Theme.surface-hover : Theme.surface-card;
                                        VerticalLayout {
                                            padding: 8px;
                                            spacing: 3px;
                                            Text {
                                                text: r.title;
                                                color: Theme.text-primary;
                                                font-size: Typography.legal;
                                                font-weight: Typography.semibold;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: r.artist;
                                                color: Theme.text-secondary;
                                                font-size: Typography.legal;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: (r.has-year ? "\{r.year}" : "—")
                                                    + (r.has-track-count ? " · \{r.track-count} " + @tr("tracks") : "")
                                                    + (r.country != "" ? " · " + r.country : "");
                                                color: Theme.text-muted;
                                                font-size: Typography.legal;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: r.format != "" ? r.format : (r.label != "" ? r.label : "");
                                                color: Theme.text-muted;
                                                font-size: Typography.legal;
                                                overflow: elide;
                                            }
                                        }
                                        card-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                TagEditorActions.select-result(r.provider_id);
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Apply + open-in-browser (when a result is selected).
                        if TagEditorState.selected_result_id != "": HorizontalLayout {
                            spacing: 8px;
                            Rectangle { horizontal-stretch: 1; }
                            // Open in browser.
                            Rectangle {
                                width: 32px;
                                height: 32px;
                                border-radius: Radius.sm;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                background: ext-ta.has-hover ? Theme.surface-hover : Theme.surface-card;
                                QbzIcon {
                                    source: @image-url("../assets/icons/external-link.svg");
                                    width: 14px;
                                    height: 14px;
                                    x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                                    y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                                    tint: Theme.text-secondary;
                                }
                                ext-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        TagEditorActions.open-in-browser();
                                    }
                                }
                            }
                            // Apply.
                            Rectangle {
                                width: apply-label.preferred-width + 28px;
                                height: 32px;
                                border-radius: Radius.sm;
                                background: apply-ta.has-hover && !TagEditorState.remote_loading
                                    ? Theme.accent-hover : Theme.accent;
                                opacity: TagEditorState.remote_loading ? 0.6 : 1.0;
                                apply-label := Text {
                                    text: TagEditorState.remote_loading ? @tr("Loading…") : @tr("Apply");
                                    color: Theme.accent-text;
                                    font-size: Typography.legal;
                                    font-weight: Typography.semibold;
                                    x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                                    y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                                }
                                apply-ta := TouchArea {
                                    mouse-cursor: TagEditorState.remote_loading ? default : pointer;
                                    clicked => {
                                        if (!TagEditorState.remote_loading) {
                                            TagEditorActions.apply-remote();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // Track table.
                Text {
                    text: @tr("Tracks");
                    color: Theme.text-muted;
                    font-size: Typography.legal;
                    font-weight: Typography.semibold;
                }
                Rectangle {
                    vertical-stretch: 1;
                    border-radius: Radius.sm;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    clip: true;
                    ScrollView {
                        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                        VerticalLayout {
                            padding: 6px;
                            spacing: 4px;
                            for row[i] in TagEditorState.tracks: HorizontalLayout {
                                spacing: 8px;
                                height: 34px;
                                // Track number.
                                LineEdit {
                                    width: 52px;
                                    placeholder-text: "#";
                                    text: row.track_number;
                                    edited(t) => {
                                        TagEditorState.tracks[i].track_number = t;
                                    }
                                }
                                // Title.
                                LineEdit {
                                    horizontal-stretch: 1;
                                    placeholder-text: @tr("Title");
                                    text: row.title;
                                    edited(t) => {
                                        TagEditorState.tracks[i].title = t;
                                    }
                                }
                                // Disc.
                                LineEdit {
                                    width: 52px;
                                    placeholder-text: @tr("Disc");
                                    text: row.disc_number;
                                    edited(t) => {
                                        TagEditorState.tracks[i].disc_number = t;
                                    }
                                }
                            }
                        }
                    }
                }

                // Album path reference.
                Text {
                    text: @tr("Album folder") + ": " + TagEditorState.directory_path;
                    color: Theme.text-muted;
                    font-size: Typography.legal;
                    overflow: elide;
                }

                // Footer: persistence picker (left) + Cancel/Save (right).
                HorizontalLayout {
                    spacing: 12px;
                    VerticalLayout {
                        alignment: center;
                        QbzSelect {
                            menu-width: 220px;
                            options: [
                                @tr("Sidecar file (recommended)"),
                                @tr("Write to audio files"),
                            ];
                            current-index: TagEditorState.persistence_index;
                            sm: true;
                            selected(i) => {
                                TagEditorActions.set-persistence(i);
                            }
                        }
                    }
                    // Direct-write warning / CUE-unsupported note.
                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        if TagEditorState.persistence_index == 1: Text {
                            text: @tr("This writes tags directly into your audio files.");
                            color: #d8a23a;
                            font-size: Typography.legal;
                            overflow: elide;
                        }
                        if !TagEditorState.can_direct_write: Text {
                            text: @tr("Direct write is unavailable for CUE-based albums.");
                            color: Theme.text-muted;
                            font-size: Typography.legal;
                            overflow: elide;
                        }
                    }
                    // Cancel.
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: cancel-label.preferred-width + 28px;
                            height: 36px;
                            border-radius: Radius.sm;
                            background: cancel-ta.has-hover ? Theme.surface-hover : transparent;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            opacity: TagEditorState.saving ? 0.5 : 1.0;
                            cancel-label := Text {
                                text: @tr("Cancel");
                                color: Theme.text-secondary;
                                font-size: Typography.body;
                                font-weight: Typography.medium;
                                x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                                y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                            }
                            cancel-ta := TouchArea {
                                mouse-cursor: TagEditorState.saving ? default : pointer;
                                clicked => {
                                    if (!TagEditorState.saving) {
                                        TagEditorActions.close();
                                    }
                                }
                            }
                        }
                    }
                    // Save.
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: save-label.preferred-width + 36px;
                            height: 36px;
                            border-radius: Radius.sm;
                            background: save-ta.has-hover && !TagEditorState.saving
                                ? Theme.accent-hover : Theme.accent;
                            opacity: TagEditorState.saving ? 0.6 : 1.0;
                            save-label := Text {
                                text: TagEditorState.write_progress_total > 0
                                    ? (@tr("Writing") + " \{TagEditorState.write_progress_current}/\{TagEditorState.write_progress_total}…")
                                    : (TagEditorState.saving ? @tr("Saving…") : @tr("Save"));
                                color: Theme.accent-text;
                                font-size: Typography.body;
                                font-weight: Typography.semibold;
                                x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                                y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                            }
                            save-ta := TouchArea {
                                mouse-cursor: TagEditorState.saving ? default : pointer;
                                clicked => {
                                    if (!TagEditorState.saving) {
                                        TagEditorActions.save();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
