// Artist detail page.
//
// An artwork-tinted gradient header (circular portrait, name, biography,
// action buttons), a Popular Tracks list, and the discography split into
// titled release sections (Albums, EPs & Singles, Live, ...). Data comes
// from the ArtistState global; action buttons are visual for now.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { ArtistState, AlbumTrackItem, NavState, ContentView } from "../state.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";
import { ContextMenu } from "../primitives/ContextMenu.slint";
import { ContextMenuItem } from "../primitives/ContextMenuItem.slint";
import { Carousel } from "../discover/Carousel.slint";

component CircleAction inherits Rectangle {
    in property <image> icon;
    in property <bool> primary: false;
    in property <length> diameter: 40px;
    callback clicked();

    width: root.diameter;
    height: root.diameter;
    border-radius: root.diameter / 2;
    background: root.primary
        ? (ta.has-hover ? Theme.accent-hover : Theme.accent)
        : (ta.has-hover ? Theme.surface-hover : Theme.surface-elevated);

    QbzIcon {
        source: root.icon;
        width: 17px;
        height: 17px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        tint: root.primary ? Theme.accent-text : Theme.text-secondary;
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

component TrackRow inherits Rectangle {
    in property <AlbumTrackItem> track;
    in property <int> index;
    callback media-action(string, string, string);

    height: 52px;
    border-radius: 8px;
    background: ta.has-hover
        ? Theme.surface-hover
        : (Math.mod(root.index, 2) == 1 ? Theme.surface-card : transparent);

    ta := TouchArea {
        mouse-cursor: default;
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 16px;

        Text {
            text: root.track.number;
            width: 28px;
            color: Theme.text-muted;
            font-size: Typography.body;
            vertical-alignment: center;
        }
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: root.track.title;
                color: Theme.text-primary;
                font-size: Typography.body;
                font-weight: Typography.medium;
                overflow: elide;
            }
        }
        Text {
            text: root.track.duration;
            width: 70px;
            color: Theme.text-muted;
            font-size: Typography.body;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        Text {
            text: root.track.quality-tier == "hires"
                ? "Hi-Res"
                : (root.track.quality-tier == "cd" ? "CD" : "");
            width: 70px;
            color: Theme.text-muted;
            font-size: Typography.legal;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        // More button — 32px square hit area, visible on row/button hover.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: Radius.sm;
                opacity: (ta.has-hover || more-ta.has-hover) ? 1.0 : 0.0;
                animate opacity { duration: 120ms; }
                background: more-ta.has-hover ? Theme.surface-elevated : transparent;
                QbzIcon {
                    source: @image-url("../assets/icons/ellipsis.svg");
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: more-ta.has-hover ? Theme.text-primary : Theme.text-secondary;
                }
                more-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        track-menu.show();
                    }
                }
            }
        }
    }

    track-menu := PopupWindow {
        x: parent.width - 208px;
        y: 44px;
        width: 196px;
        height: 109px;
        ContextMenu {
            ContextMenuItem {
                icon: @image-url("../assets/icons/play.svg");
                label: @tr("Play");
                clicked => {
                    root.media-action("track", root.track.id, "play");
                }
            }
            ContextMenuItem {
                icon: @image-url("../assets/icons/list-plus.svg");
                label: @tr("Add to queue");
                clicked => {
                    root.media-action("track", root.track.id, "queue");
                }
            }
            ContextMenuItem {
                icon: @image-url("../assets/icons/heart.svg");
                label: @tr("Add to favorites");
                clicked => {
                    root.media-action("track", root.track.id, "favorite");
                }
            }
        }
    }
}

component SectionTitle inherits Text {
    color: Theme.text-primary;
    font-size: Typography.heading;
    font-weight: Typography.semibold;
}

export component ArtistPageView inherits Rectangle {
    callback open-album(string);
    callback media-action(string, string, string);

    background: Theme.surface-main;

    Flickable {
        viewport-width: self.width;
        viewport-height: page.preferred-height;

        // Artwork-tinted gradient behind the header; scrolls with content.
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: 340px;
            background: @linear-gradient(180deg,
                ArtistState.header-color 0%,
                transparent 100%);
        }

        page := VerticalLayout {
            width: parent.width;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 14px;
            padding-bottom: 100px;
            spacing: 0px;
            alignment: start;

            // --- Back button -------------------------------------------------
            back := TouchArea {
                width: back-row.preferred-width;
                height: 28px;
                mouse-cursor: pointer;
                clicked => {
                    NavState.view = ContentView.home;
                }
                back-row := HorizontalLayout {
                    spacing: 6px;
                    VerticalLayout {
                        alignment: center;
                        QbzIcon {
                            source: @image-url("../assets/icons/arrow-left.svg");
                            width: 16px;
                            height: 16px;
                            tint: back.has-hover ? Theme.text-secondary : Theme.text-muted;
                        }
                    }
                    Text {
                        text: @tr("Back");
                        color: back.has-hover ? Theme.text-secondary : Theme.text-muted;
                        font-size: Typography.body;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle { height: 22px; }

            // --- Artist header -----------------------------------------------
            HorizontalLayout {
                spacing: 32px;
                alignment: start;

                Rectangle {
                    width: 200px;
                    height: 200px;
                    border-radius: 100px;
                    background: Theme.surface-elevated;
                    drop-shadow-blur: 32px;
                    drop-shadow-color: #00000080;
                    drop-shadow-offset-y: 8px;
                    clip: true;
                    Image {
                        width: 100%;
                        height: 100%;
                        source: ArtistState.artwork;
                        image-fit: cover;
                    }
                }

                VerticalLayout {
                    alignment: start;
                    padding-top: 8px;
                    spacing: 0px;
                    horizontal-stretch: 1;

                    Text {
                        text: @tr("ARTIST");
                        color: Theme.text-muted;
                        font-size: 10px;
                        font-weight: Typography.semibold;
                        letter-spacing: 1.5px;
                    }
                    Rectangle { height: 6px; }
                    Text {
                        text: ArtistState.name;
                        color: Theme.text-primary;
                        font-size: Typography.title;
                        font-weight: Typography.bold;
                        overflow: elide;
                    }
                    Rectangle { height: 12px; }
                    Text {
                        text: ArtistState.bio;
                        visible: ArtistState.bio != "";
                        color: Theme.text-secondary;
                        font-size: Typography.body;
                        wrap: word-wrap;
                    }
                    Rectangle { height: 20px; }
                    HorizontalLayout {
                        alignment: start;
                        spacing: 12px;
                        CircleAction {
                            icon: @image-url("../assets/icons/play-fill.svg");
                            primary: true;
                            diameter: 44px;
                        }
                        VerticalLayout {
                            alignment: center;
                            CircleAction { icon: @image-url("../assets/icons/heart.svg"); }
                        }
                        VerticalLayout {
                            alignment: center;
                            CircleAction { icon: @image-url("../assets/icons/radio.svg"); }
                        }
                        VerticalLayout {
                            alignment: center;
                            CircleAction { icon: @image-url("../assets/icons/library-big.svg"); }
                        }
                        VerticalLayout {
                            alignment: center;
                            CircleAction { icon: @image-url("../assets/icons/ellipsis.svg"); }
                        }
                    }
                }
            }

            Rectangle { height: 36px; }

            if ArtistState.loading && ArtistState.top-tracks.length == 0: Text {
                text: @tr("Loading artist...");
                color: Theme.text-muted;
                font-size: Typography.body;
            }

            // --- Popular tracks ----------------------------------------------
            if ArtistState.top-tracks.length > 0: SectionTitle {
                text: @tr("Popular Tracks");
            }
            if ArtistState.top-tracks.length > 0: Rectangle { height: 10px; }
            for track[index] in ArtistState.top-tracks: TrackRow {
                track: track;
                index: index;
                media-action(kind, id, action) => {
                    root.media-action(kind, id, action);
                }
            }

            // --- Release sections (Albums, EPs & Singles, Live, ...) ---------
            for section in ArtistState.release-sections: VerticalLayout {
                spacing: 0px;
                Rectangle { height: 32px; }
                Carousel {
                    section: section;
                    album-clicked(id) => {
                        root.open-album(id);
                    }
                    media-action(kind, id, action) => {
                        root.media-action(kind, id, action);
                    }
                }
            }
        }
    }
}
