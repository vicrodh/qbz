msgstr "Открыть музыкальную ссылку"

msgid "Open Playlist Importer"
msgstr "Открыть импорт плейлистов"

msgid "Open Qobuz Link"
msgstr "Открыть ссылку Qobuz"

msgid "Paste a Qobuz, Spotify, Apple Music, Tidal, Deezer or song.link URL"
