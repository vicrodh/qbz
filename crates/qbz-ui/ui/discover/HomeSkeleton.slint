// Loading skeleton for the Discover home — grey placeholder blocks
// shaped like the real carousels, gently pulsing (fade in/out) while
// the first fetch is in flight. Replaces the spinner + "Loading…"
// text so the first paint reads as the page filling in rather than a
// generic loader.

import { Theme } from "../foundation/semantic-colors.slint";
import { Radius } from "../foundation/radius.slint";
import { ShellState } from "../state.slint";

// A single shimmering block. Opacity breathes between two values on a
// shared phase so the whole skeleton pulses in unison. Under reduce-motion
// the fade collapses to a snap: the 900ms Timer still flips the phase, but
// no continuous opacity animation runs between flips (~1fps repaints
// instead of display-rate while the skeleton is mounted).
component Shimmer inherits Rectangle {
    in property <bool> phase;
    background: Theme.surface-elevated;
    border-radius: Radius.sm;
    opacity: root.phase ? 0.85 : 0.4;
    animate opacity {
        duration: ShellState.reduce-motion ? 0ms : 900ms;
        easing: ease-in-out;
    }
}

// One placeholder carousel: a short title bar over a row of card
// blocks (square art + two text lines).
component SkeletonRow inherits VerticalLayout {
    in property <bool> phase;
    in property <length> card-size: 200px;
    spacing: 12px;

    Shimmer {
        phase: root.phase;
        width: 180px;
        height: 22px;
    }
    HorizontalLayout {
        spacing: 32px;
        for _ in [0, 1, 2, 3, 4]: VerticalLayout {
            spacing: 8px;
            Shimmer {
                phase: root.phase;
                width: root.card-size;
                height: root.card-size;
            }
            Shimmer {
                phase: root.phase;
                width: root.card-size * 0.7;
                height: 14px;
            }
            Shimmer {
                phase: root.phase;
                width: root.card-size * 0.45;
                height: 12px;
            }
        }
    }
}

export component HomeSkeleton inherits VerticalLayout {
    property <bool> phase: false;
    spacing: 40px;

    // Drives the shared breathing phase.
    Timer {
        interval: 900ms;
        running: true;
        triggered => {
            root.phase = !root.phase;
        }
    }

    SkeletonRow { phase: root.phase; }
    SkeletonRow { phase: root.phase; }
}

// ── Standalone per-row skeletons (Discover > Recommendations) ───────────────
//
// Each owns its breathing Timer so it can drop into a layout in place of a row
// whose builder has not resolved yet. Shapes mirror the real rows: a card
// carousel (artists/albums) and a slim 4-wide track grid (Weekly playlists).

// Card-carousel placeholder: title bar + a row of card blocks (art + 2 lines).
export component SkeletonCarouselRow inherits VerticalLayout {
    in property <length> card-size: 180px;
    property <bool> phase: false;
    spacing: 12px;

    Timer {
        interval: 900ms;
        running: true;
        triggered => {
            root.phase = !root.phase;
        }
    }

    Shimmer {
        phase: root.phase;
        width: 180px;
        height: 22px;
    }
    HorizontalLayout {
        spacing: 24px;
        for _ in [0, 1, 2, 3, 4, 5]: VerticalLayout {
            spacing: 8px;
            Shimmer {
                phase: root.phase;
                width: root.card-size;
                height: root.card-size;
            }
            Shimmer {
                phase: root.phase;
                width: root.card-size * 0.7;
                height: 14px;
            }
            Shimmer {
                phase: root.phase;
                width: root.card-size * 0.45;
                height: 12px;
            }
        }
    }
}

// Slim-grid placeholder: title bar + a 4-column x 3-row grid of slim row
// blocks, matching SlimCarousel's 4x3 layout (the Weekly Exploration/Jams rows).
export component SkeletonSlimRow inherits VerticalLayout {
    property <bool> phase: false;
    spacing: 12px;

    Timer {
        interval: 900ms;
        running: true;
        triggered => {
            root.phase = !root.phase;
        }
    }

    Shimmer {
        phase: root.phase;
        width: 180px;
        height: 22px;
    }
    HorizontalLayout {
        spacing: 8px;
        for _ in [0, 1, 2, 3]: Shimmer {
            phase: root.phase;
            height: 60px;
            horizontal-stretch: 1;
        }
    }
    HorizontalLayout {
        spacing: 8px;
        for _ in [0, 1, 2, 3]: Shimmer {
            phase: root.phase;
            height: 60px;
            horizontal-stretch: 1;
        }
    }
    HorizontalLayout {
        spacing: 8px;
        for _ in [0, 1, 2, 3]: Shimmer {
            phase: root.phase;
            height: 60px;
            horizontal-stretch: 1;
        }
    }
}
