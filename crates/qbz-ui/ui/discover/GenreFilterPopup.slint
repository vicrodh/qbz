// Filter-by-genre popup — ported from Tauri's GenreFilterPopup.
// Simple grid view (parent genres as selectable chips) plus the Advanced
// view (search + 3-level tree + counts). The selection is shared across
// the three Discover tabs and re-fetches the discover index.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { GenreFilterState, GenreFilterActions, GenreChip, GenreTreeRow, UiFocusState } from "../state.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";
import { QbzToggle } from "../primitives/QbzToggle.slint";

// One row of the advanced-view tree: indent + expand arrow + checkbox
// + name + child count.
component GenreTreeRowItem inherits Rectangle {
    in property <GenreTreeRow> node;
    callback toggle(string);
    callback toggle-expand(string);

    height: 34px;
    border-radius: 6px;
    background: ta.has-hover ? Theme.surface-hover : transparent;

    // Row click (outside the arrow) toggles selection. Declared FIRST so it
    // sits BELOW the arrow's TouchArea in z-order (later siblings are on top
    // in Slint) — otherwise it swallows the chevron click and sub-genres
    // never expand (#545).
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.toggle(root.node.id);
        }
    }

    HorizontalLayout {
        padding-left: 6px + root.node.level * 18px;
        padding-right: 10px;
        spacing: 6px;

        // Expand arrow (parents / children with kids).
        Rectangle {
            width: 20px;
            VerticalLayout {
                alignment: center;
                if root.node.has-children: QbzIcon {
                    source: root.node.expanded
                        ? @image-url("../assets/icons/chevron-down.svg")
                        : @image-url("../assets/icons/chevron-right.svg");
                    width: 13px;
                    height: 13px;
                    tint: Theme.text-muted;
                }
            }
            arrow-ta := TouchArea {
                mouse-cursor: root.node.has-children ? pointer : default;
                clicked => {
                    if (root.node.has-children) {
                        root.toggle-expand(root.node.id);
                    }
                }
            }
        }

        // Checkbox.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 16px;
                height: 16px;
                border-radius: 4px;
                border-width: 1.5px;
                border-color: root.node.selected ? Theme.accent : Theme.border-muted;
                background: root.node.selected ? Theme.accent : transparent;
                QbzIcon {
                    visible: root.node.selected;
                    source: @image-url("../assets/icons/check.svg");
                    width: 11px;
                    height: 11px;
                    x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                    y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                    tint: #ffffff;
                }
            }
        }

        Text {
            text: root.node.name;
            color: root.node.selected ? Theme.text-primary : Theme.text-secondary;
            font-size: 13px;
            font-weight: root.node.level == 0 ? Typography.medium : Typography.regular;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        if root.node.count > 0: Text {
            text: root.node.count;
            color: Theme.text-muted;
            font-size: Typography.legal;
            vertical-alignment: center;
        }
    }

}

component GenreCard inherits Rectangle {
    in property <GenreChip> chip;
    callback clicked(string);

    height: 38px;
    border-radius: 6px;
    background: root.chip.selected
        ? Theme.accent
        : (ta.has-hover ? Theme.surface-hover : Theme.surface-elevated);

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        Text {
            text: root.chip.name;
            color: root.chip.selected ? #ffffff : Theme.text-secondary;
            font-size: 13px;
            font-weight: root.chip.selected ? Typography.medium : Typography.regular;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        // Check circle.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 16px;
                height: 16px;
                border-radius: 8px;
                border-width: 1.5px;
                border-color: root.chip.selected ? #ffffff : Theme.border-muted;
                background: root.chip.selected ? #ffffff : transparent;
                QbzIcon {
                    visible: root.chip.selected;
                    source: @image-url("../assets/icons/check.svg");
                    width: 11px;
                    height: 11px;
                    x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                    y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                    tint: Theme.accent;
                }
            }
        }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked(root.chip.id);
        }
    }
}

export component GenreFilterPopup inherits Rectangle {
    property <int> columns: 3;
    property <length> grid-gap: 8px;
    property <length> chip-height: 38px;

    width: 470px;
    // Hug the content vertically — without an explicit height a
    // Rectangle child fills its parent (the whole view), which made
    // the popup grow to full window height.
    height: content.preferred-height;
    background: Theme.surface-main;
    border-radius: Radius.md;
    border-width: 1px;
    border-color: Theme.border-muted;
    drop-shadow-blur: 28px;
    drop-shadow-color: #00000080;
    drop-shadow-offset-y: 8px;

    content := VerticalLayout {
        padding: 16px;
        spacing: 14px;

        // --- Header --------------------------------------------------
        HorizontalLayout {
            spacing: 8px;
            VerticalLayout {
                alignment: center;
                QbzIcon {
                    source: @image-url("../assets/icons/list-filter.svg");
                    width: 16px;
                    height: 16px;
                    tint: Theme.text-secondary;
                }
            }
            Text {
                text: @tr("Filter by genre");
                color: Theme.text-primary;
                font-size: Typography.heading;
                font-weight: Typography.semibold;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            Rectangle {
                width: 26px;
                height: 26px;
                border-radius: 6px;
                background: close-ta.has-hover ? Theme.surface-hover : transparent;
                QbzIcon {
                    source: @image-url("../assets/icons/x.svg");
                    width: 15px;
                    height: 15px;
                    x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                    y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                    tint: close-ta.has-hover ? Theme.text-primary : Theme.text-muted;
                }
                close-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        GenreFilterState.open = false;
                    }
                }
            }
        }

        // --- Options row: Remember selection + Advanced view ---------
        HorizontalLayout {
            spacing: 16px;
            HorizontalLayout {
                spacing: 10px;
                horizontal-stretch: 1;
                Text {
                    text: @tr("Remember selection");
                    color: Theme.text-secondary;
                    font-size: 13px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                VerticalLayout {
                    alignment: center;
                    QbzToggle {
                        checked: GenreFilterState.remember;
                        toggled(v) => {
                            GenreFilterActions.set-remember(v);
                        }
                    }
                }
            }
            HorizontalLayout {
                spacing: 10px;
                horizontal-stretch: 1;
                Text {
                    text: @tr("Advanced view");
                    color: Theme.text-secondary;
                    font-size: 13px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                VerticalLayout {
                    alignment: center;
                    QbzToggle {
                        checked: GenreFilterState.advanced;
                        toggled(v) => {
                            GenreFilterActions.set-advanced(v);
                        }
                    }
                }
            }
        }

        // --- Advanced view: search + 3-level genre tree -------------
        if GenreFilterState.advanced: VerticalLayout {
            spacing: 10px;

            // Search box.
            Rectangle {
                height: 34px;
                border-radius: 6px;
                background: Theme.surface-elevated;
                border-width: 1px;
                border-color: search-input.has-focus ? Theme.border-subtle : Theme.surface-elevated;
                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 8px;
                    VerticalLayout {
                        alignment: center;
                        QbzIcon {
                            source: @image-url("../assets/icons/search.svg");
                            width: 14px;
                            height: 14px;
                            tint: Theme.text-muted;
                        }
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        search-input := TextInput {
                            width: 100%;
                            height: 100%;
                            color: Theme.text-primary;
                            font-size: 13px;
                            vertical-alignment: center;
                            single-line: true;
                            text <=> GenreFilterState.search-query;
                            changed has-focus => { UiFocusState.text-input-focused = self.has-focus; }
                            edited => {
                                GenreFilterActions.search(self.text);
                            }
                        }
                        Text {
                            visible: search-input.text == "";
                            text: @tr("Search genres…");
                            color: Theme.text-muted;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // Tree (scrollable).
            Flickable {
                height: 320px;
                viewport-width: self.width;
                viewport-height: tree-col.preferred-height;
                tree-col := VerticalLayout {
                    spacing: 1px;
                    for entry in GenreFilterState.tree: GenreTreeRowItem {
                        node: entry;
                        toggle(id) => {
                            GenreFilterActions.toggle(id);
                        }
                        toggle-expand(id) => {
                            GenreFilterActions.toggle-expand(id);
                        }
                    }
                }
            }
        }

        // --- Simple grid: parent genres as chips ---------------------
        if !GenreFilterState.advanced: grid := Rectangle {
            property <int> count: GenreFilterState.genres.length;
            property <int> rows: Math.ceil(self.count / root.columns);
            property <length> cell-width:
                (self.width - (root.columns - 1) * root.grid-gap) / root.columns;
            height: self.rows > 0
                ? self.rows * root.chip-height + Math.max(0, self.rows - 1) * root.grid-gap
                : 0px;

            for chip[i] in GenreFilterState.genres: GenreCard {
                chip: chip;
                width: grid.cell-width;
                x: Math.mod(i, root.columns) * (grid.cell-width + root.grid-gap);
                y: Math.floor(i / root.columns) * (root.chip-height + root.grid-gap);
                clicked(id) => {
                    GenreFilterActions.toggle(id);
                }
            }
        }

        // --- Footer: Clear filter ------------------------------------
        Rectangle {
            height: 34px;
            border-radius: 6px;
            background: clear-ta.has-hover && GenreFilterState.selected-count > 0
                ? Theme.surface-hover
                : Theme.surface-elevated;
            opacity: GenreFilterState.selected-count > 0 ? 1.0 : 0.5;
            Text {
                text: @tr("Clear filter");
                color: Theme.text-secondary;
                font-size: 13px;
                x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
            }
            clear-ta := TouchArea {
                mouse-cursor: GenreFilterState.selected-count > 0 ? pointer : default;
                clicked => {
                    if (GenreFilterState.selected-count > 0) {
                        GenreFilterActions.clear();
                    }
                }
            }
        }
    }
}
