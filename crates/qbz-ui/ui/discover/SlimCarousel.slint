// A paginated slim-card section (Recently Played Tracks, Popular
// albums). 12 items per page (4 columns x 3 rows), capped at two
// pages. The prev/next controls only appear when there is more than
// one page; the track slides horizontally by a full viewport width.
//
// Mirrors the Tauri home: a 4x3 grid that pages rather than growing
// into a tall wall of rows.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { SlimItem } from "../state.slint";
import { SlimCard } from "SlimCard.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";

component NavButton inherits Rectangle {
    in property <image> icon;
    in property <bool> enabled: true;
    callback clicked();

    width: 28px;
    height: 28px;
    border-radius: 14px;
    opacity: root.enabled ? 1.0 : 0.4;
    background: ta.has-hover && root.enabled
        ? Theme.surface-hover
        : Theme.surface-elevated;

    QbzIcon {
        source: root.icon;
        width: 15px;
        height: 15px;
        x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
        y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
        tint: root.enabled ? Theme.text-primary : Theme.text-muted;
    }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.clicked();
        }
    }
}

export component SlimCarousel inherits VerticalLayout {
    in property <string> title;
    in property <[SlimItem]> items;
    callback item-clicked(string);
    // P7: optional title-adjacent list actions ("add to queue" / "create
    // playlist from this list"). Off by default so the shared SlimCarousel rows
    // (recent, popular) are unchanged; only the Weekly rows opt in.
    in property <bool> show-list-actions: false;
    callback list-action(string);
    // Optional refresh affordance in the row header (recently-played rows).
    // Shown regardless of page count, unlike the chevrons.
    in property <bool> show-refresh: false;
    callback refresh-clicked();

    property <int> columns: 4;
    property <int> rows: 3;
    property <length> gap: 8px;
    property <length> row-height: 60px;
    property <int> per-page: root.columns * root.rows; // 12
    // Cap at two pages (24 items); excess is not shown.
    property <int> total: Math.min(root.items.length, 2 * root.per-page);
    property <int> page-count: Math.max(1, Math.ceil(root.total / root.per-page));
    // Max leftward scroll (viewport-x is 0 at start, negative scrolled).
    property <length> max-scroll: Math.max(0px, (root.page-count - 1) * flick.width);

    spacing: 12px;

    // --- Header: title + (conditional) page controls ---------------------
    HorizontalLayout {
        Text {
            text: root.title;
            color: Theme.text-primary;
            font-size: 18px;
            font-weight: Typography.semibold;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        // Title-adjacent list actions (P7): add the whole backing list to the
        // queue / create a playlist from it. Icon buttons (ADR-008, no pills).
        if root.show-list-actions: HorizontalLayout {
            spacing: 4px;
            VerticalLayout {
                alignment: center;
                NavButton {
                    icon: @image-url("../assets/icons/list-end.svg");
                    clicked => {
                        root.list-action("queue");
                    }
                }
            }
            VerticalLayout {
                alignment: center;
                NavButton {
                    icon: @image-url("../assets/icons/list-music.svg");
                    clicked => {
                        root.list-action("create-playlist");
                    }
                }
            }
        }
        if root.show-refresh: HorizontalLayout {
            spacing: 4px;
            VerticalLayout {
                alignment: center;
                NavButton {
                    icon: @image-url("../assets/icons/refresh-cw.svg");
                    clicked => {
                        root.refresh-clicked();
                    }
                }
            }
        }
        // Only when there is a second page.
        if root.total > root.per-page: HorizontalLayout {
            spacing: 4px;
            VerticalLayout {
                alignment: center;
                NavButton {
                    icon: @image-url("../assets/icons/chevron-left.svg");
                    enabled: flick.viewport-x < -1px;
                    clicked => {
                        flick.viewport-x = Math.min(0px, flick.viewport-x + flick.width);
                    }
                }
            }
            VerticalLayout {
                alignment: center;
                NavButton {
                    icon: @image-url("../assets/icons/chevron-right.svg");
                    enabled: flick.viewport-x > -root.max-scroll + 1px;
                    clicked => {
                        flick.viewport-x = Math.max(-root.max-scroll, flick.viewport-x - flick.width);
                    }
                }
            }
        }
    }

    // --- Track: a horizontal Flickable so the grid drags by page like
    // the album carousel. Each page block is one viewport width wide; the
    // 4x3 cards are positioned absolutely inside their page block. Card
    // taps still register (Flickable separates flick from tap).
    viewport := Rectangle {
        height: root.rows * root.row-height + (root.rows - 1) * root.gap;
        clip: true;

        flick := Flickable {
            width: 100%;
            height: parent.height;
            viewport-width: root.page-count * self.width;
            viewport-height: self.height;

            property <length> cell-width:
                (self.width - (root.columns - 1) * root.gap) / root.columns;

            for item[i] in root.items: SlimCard {
                // Only the first `total` items are laid out; the rest
                // (beyond two pages) collapse to zero and stay off-screen.
                property <bool> shown: i < root.total;
                property <int> slot: Math.mod(i, root.per-page);
                property <int> page-idx: Math.floor(i / root.per-page);
                property <int> slot-col: Math.mod(self.slot, root.columns);
                property <int> slot-row: Math.floor(self.slot / root.columns);
                visible: self.shown;
                width: self.shown ? flick.cell-width : 0px;
                height: root.row-height;
                x: self.page-idx * flick.width
                    + self.slot-col * (flick.cell-width + root.gap);
                y: self.slot-row * (root.row-height + root.gap);
                item: item;
                clicked(id) => {
                    root.item-clicked(id);
                }
            }
        }
    }
}
