// Playlist card — the album card's twin for playlists: a 162px cover (a
// collage of up to four covers), a hover overlay with favorite / play /
// more, and a title / subtitle stack. No quality badge, no award ribbon.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { Spacing } from "../foundation/spacing.slint";
import { SearchPlaylistItem, PinnedActions } from "../state.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";
import { ContextMenu } from "../primitives/ContextMenu.slint";
import { ContextMenuItem } from "../primitives/ContextMenuItem.slint";
import { PlaylistCollage } from "PlaylistCollage.slint";

component OverlayButton inherits Rectangle {
    in property <image> icon;
    in property <bool> primary: false;
    in property <length> diameter: 36px;
    in property <length> icon-size: 16px;
    out property <bool> hovered: ta.has-hover;
    callback clicked();

    width: root.diameter;
    height: root.diameter;
    border-radius: root.diameter / 2;
    background: root.primary
        ? (ta.has-hover ? #ffffffd6 : #ffffff)
        : (ta.has-hover ? #ffffff3d : #ffffff24);
    border-width: root.primary ? 0px : 1.5px;
    border-color: #ffffffcc;

    QbzIcon {
        source: root.icon;
        width: root.icon-size;
        height: root.icon-size;
        x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
        y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
        tint: root.primary ? #000000 : #ffffff;
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component PlaylistCard inherits Rectangle {
    in property <SearchPlaylistItem> playlist;
    // kind ("playlist"), playlist id, action ("play" | "play-next" |
    // "queue" | "favorite" | "open").
    callback media-action(string, string, string);
    // When true, a click on the card BODY opens the playlist ("open")
    // instead of playing it — the Favorites grid wants body=open, the play
    // button=play. Discover/Search leave it false (body=play), unchanged.
    in property <bool> body-opens: false;

    width: 200px;
    height: 246px;

    property <bool> overlay-on: hover.has-hover
        || fav-btn.hovered || play-btn.hovered || more-btn.hovered
        || pin-ta.has-hover;

    VerticalLayout {
        alignment: start;
        spacing: 0px;

        // --- Cover collage + hover overlay -------------------------------
        Rectangle {
            width: 200px;
            height: 200px;
            border-radius: Radius.sm;
            clip: true;

            PlaylistCollage {
                playlist: root.playlist;
                size: 200px;
            }

            Rectangle {
                width: 100%;
                height: 100%;
                background: #000000;
                opacity: root.overlay-on ? 0.6 : 0.0;
                animate opacity { duration: 150ms; }
            }

            hover := TouchArea {
                width: 100%;
                height: 100%;
                mouse-cursor: pointer;
                clicked => {
                    root.media-action("playlist", root.playlist.id, root.body-opens ? "open" : "play");
                }
            }

            HorizontalLayout {
                x: 0px;
                y: 120px;
                width: 200px;
                height: 44px;
                alignment: center;
                spacing: 12px;
                opacity: root.overlay-on ? 1.0 : 0.0;
                animate opacity { duration: 150ms; }

                VerticalLayout {
                    alignment: center;
                    fav-btn := OverlayButton {
                        icon: @image-url("../assets/icons/heart.svg");
                        clicked => {
                            root.media-action("playlist", root.playlist.id, "favorite");
                        }
                    }
                }
                play-btn := OverlayButton {
                    icon: @image-url("../assets/icons/play-fill.svg");
                    primary: true;
                    diameter: 44px;
                    icon-size: 18px;
                    clicked => {
                        root.media-action("playlist", root.playlist.id, "play");
                    }
                }
                VerticalLayout {
                    alignment: center;
                    more-btn := OverlayButton {
                        icon: @image-url("../assets/icons/ellipsis.svg");
                        clicked => {
                            playlist-menu.show();
                        }
                    }
                }
            }

            // Pin glyph — top-right of the cover. Filled accent pin always
            // visible when pinned (state indicator); outline pin
            // hover-revealed otherwise. Always-mounted (opacity, not `if`)
            // so its TouchArea's has-hover can join `overlay-on` above.
            pin-badge := Rectangle {
                x: parent.width - self.width - 8px;
                y: 8px;
                width: 26px;
                height: 26px;
                border-radius: 13px;
                background: pin-ta.has-hover ? #000000cc : #00000099;
                opacity: root.overlay-on ? 1.0 : 0.0;
                animate opacity { duration: 150ms; }
                QbzIcon {
                    source: root.playlist.is-pinned
                        ? @image-url("../assets/icons/pin-filled.svg")
                        : @image-url("../assets/icons/pin.svg");
                    width: 14px;
                    height: 14px;
                    x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                    y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                    tint: root.playlist.is-pinned ? Theme.accent : #ffffff;
                }
                pin-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        PinnedActions.toggle-pin("playlist", root.playlist.id,
                            root.playlist.title, root.playlist.subtitle,
                            root.playlist.url1);
                    }
                }
            }

            playlist-menu := PopupWindow {
                x: 26px;
                y: 56px;
                width: 196px;
                height: 109px;
                ContextMenu {
                    ContextMenuItem {
                        icon: @image-url("../assets/icons/play.svg");
                        label: @tr("Play");
                        clicked => {
                            root.media-action("playlist", root.playlist.id, "play");
                        }
                    }
                    ContextMenuItem {
                        icon: @image-url("../assets/icons/list-plus.svg");
                        label: @tr("Play next");
                        clicked => {
                            root.media-action("playlist", root.playlist.id, "play-next");
                        }
                    }
                    ContextMenuItem {
                        icon: @image-url("../assets/icons/list-end.svg");
                        label: @tr("Add to queue");
                        clicked => {
                            root.media-action("playlist", root.playlist.id, "queue");
                        }
                    }
                    ContextMenuItem {
                        icon: @image-url("../assets/icons/heart.svg");
                        label: @tr("Add to Library");
                        clicked => {
                            root.media-action("playlist", root.playlist.id, "favorite");
                        }
                    }
                }
            }
        }

        Rectangle { height: 6px; }

        // --- Title / subtitle line ---------------------------------------
        // The second line is the playlist's category tag (Discover cards) OR,
        // when there is no tag, the muted subtitle (owner / track count — used
        // by the Search + Favorites grids). The category is an UPPERCASE accent
        // eyebrow (uppercased in Rust; Slint has no text-transform), styled like
        // the QbzSelect "BP"/section-header accent-caps. Mutually exclusive so
        // the slot never doubles up.
        VerticalLayout {
            height: 40px;
            spacing: 2px;
            padding-left: Spacing.xs;
            Text {
                text: root.playlist.title;
                height: 20px;
                color: Theme.text-primary;
                font-size: Typography.body - 2px;
                font-weight: Typography.semibold;
                vertical-alignment: center;
                overflow: elide;
            }
            if root.playlist.category != "": Text {
                text: root.playlist.category;
                height: 16px;
                color: Theme.accent;
                font-size: 11px;
                font-weight: Typography.semibold;
                letter-spacing: 0.5px;
                vertical-alignment: center;
                overflow: elide;
            }
            if root.playlist.category == "": Text {
                text: root.playlist.subtitle;
                height: 16px;
                color: Theme.text-muted;
                font-size: Typography.link - 1px;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }
}
