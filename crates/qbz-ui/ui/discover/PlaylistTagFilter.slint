// Qobuz Playlists category filter — a compact multi-select dropdown that
// replaces the old WebPlayer category pills (ADR-008: no pills). The button
// shows "Filter by category" (or "N selected") and opens a checkbox list of
// the discover-index `playlists_tags`. Toggling a tag re-filters the cached
// playlists row client-side (union of selected tags); an empty selection
// shows everything. Tag NAMES are pre-localized by the response; the chrome
// ("Filter by category", "All", "Clear") uses @tr literals.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { HomeState, HomeActions, PlaylistTagItem, ShellState, AppearanceState } from "../state.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";

// One checkbox row in the open list: a square check + the localized tag name.
component TagRow inherits Rectangle {
    in property <PlaylistTagItem> tag;
    callback toggle(string);

    height: 32px;
    background: ta.has-hover ? Theme.surface-hover : transparent;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 16px;
                height: 16px;
                border-radius: 4px;
                border-width: 1.5px;
                border-color: root.tag.selected ? Theme.accent : Theme.border-muted;
                background: root.tag.selected ? Theme.accent : transparent;
                QbzIcon {
                    visible: root.tag.selected;
                    source: @image-url("../assets/icons/check.svg");
                    width: 11px;
                    height: 11px;
                    x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                    y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                    tint: #ffffff;
                }
            }
        }
        Text {
            text: root.tag.name;
            color: root.tag.selected ? Theme.text-primary : Theme.text-secondary;
            font-size: 12px;
            font-weight: root.tag.selected ? Typography.medium : Typography.regular;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.toggle(root.tag.slug);
        }
    }
}

export component PlaylistTagFilter inherits Rectangle {
    // Collapsed control: a 34px settings-style dropdown button.
    private property <length> control-width: 220px;
    private property <length> max-list-height: 320px;

    width: root.control-width;
    // sm variant — matches QbzSelect { sm: true } used by the toolbar
    // selects (favorites Group / Sort): 30px tall, 6px radius, no outline.
    height: 30px;
    border-radius: 6px;
    border-width: 0px;
    background: ta.has-hover ? Theme.surface-hover : (ShellState.app-background-active ? Theme.surface-elevated.with-alpha(AppearanceState.app-background-surface-alpha) : Theme.surface-elevated);

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 8px;
        spacing: 8px;
        VerticalLayout {
            alignment: center;
            QbzIcon {
                source: @image-url("../assets/icons/list-filter.svg");
                width: 13px;
                height: 13px;
                tint: Theme.text-muted;
            }
        }
        Text {
            text: HomeState.playlist-tag-count > 0
                ? @tr("{} selected", HomeState.playlist-tag-count)
                : @tr("Filter by category");
            color: HomeState.playlist-tag-count > 0 ? Theme.text-primary : Theme.text-secondary;
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        VerticalLayout {
            alignment: center;
            QbzIcon {
                source: @image-url("../assets/icons/chevron-down.svg");
                width: 14px;
                height: 14px;
                tint: Theme.text-muted;
            }
        }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            popup.show();
        }
    }

    popup := PopupWindow {
        x: 0px;
        y: root.height + 4px;
        width: root.control-width;
        // List (capped + scrolling) + the 32px "All categories" footer + the
        // 10px vertical padding of the inner column. Reading the capped list
        // height (not the child rows) keeps this loop-free.
        height: Math.min(list-col.preferred-height, root.max-list-height) + 32px + 10px;

        Rectangle {
            background: Theme.surface-main;
            border-radius: Radius.sm;
            border-width: 1px;
            border-color: Theme.border-muted;
            drop-shadow-blur: 20px;
            drop-shadow-color: #00000080;
            drop-shadow-offset-y: 5px;

            VerticalLayout {
                padding-top: 5px;
                padding-bottom: 5px;

                Flickable {
                    height: Math.min(list-col.preferred-height, root.max-list-height);
                    viewport-width: self.width;
                    viewport-height: list-col.preferred-height;

                    list-col := VerticalLayout {
                        for tag in HomeState.playlist-tags: TagRow {
                            tag: tag;
                            toggle(slug) => {
                                HomeActions.toggle-playlist-tag(slug);
                            }
                        }
                    }
                }

                // "Clear / show all" footer — disabled (dimmed) when nothing
                // is selected.
                clear-row := Rectangle {
                    height: 32px;
                    background: clear-ta.has-hover && HomeState.playlist-tag-count > 0
                        ? Theme.surface-hover
                        : transparent;
                    opacity: HomeState.playlist-tag-count > 0 ? 1.0 : 0.5;
                    Text {
                        text: @tr("All categories");
                        color: Theme.text-secondary;
                        font-size: 12px;
                        x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                        y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                    }
                    clear-ta := TouchArea {
                        mouse-cursor: HomeState.playlist-tag-count > 0 ? pointer : default;
                        clicked => {
                            if (HomeState.playlist-tag-count > 0) {
                                HomeActions.clear-playlist-tags();
                            }
                        }
                    }
                }
            }
        }
    }
}
