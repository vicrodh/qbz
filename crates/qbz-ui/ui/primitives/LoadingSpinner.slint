// Loading spinner — a rotating 3/4 arc (Lucide LoaderCircle). Matches the
// Tauri `.spinner` (32px, 1s linear infinite). Used for heavy loads where
// `LoadingDots` reads too lightweight.

import { Theme } from "../foundation/semantic-colors.slint";
import { ShellState } from "../state.slint";

export component LoadingSpinner inherits Rectangle {
    in property <length> size: 32px;
    in property <color> tint: Theme.accent;

    // Reduce-motion: step from the shared ~8fps coarse clock instead of the
    // display-rate animation-tick (each step is a full-window repaint on
    // femtovg). 125ms * 0.36 = 45deg per step — a clean 8-step spin.
    property <float> anim-ms: ShellState.reduce-motion
        ? ShellState.coarse-tick-ms * 1.0
        : animation-tick() / 1ms;

    width: root.size;
    height: root.size;

    Image {
        width: root.size;
        height: root.size;
        source: @image-url("../assets/icons/loader-circle.svg");
        colorize: root.tint;
        // Linear 1s/full-turn spin (360deg / 1000ms).
        transform-rotation: (root.anim-ms * 0.36) * 1deg;
    }
}
