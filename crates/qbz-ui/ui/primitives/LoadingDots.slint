// Loading indicator — three pulsing dots above an optional label. A
// lightweight replacement for empty-color placeholders during heavy
// loads (search, large grids, the playlist manager, etc.).

import { Theme } from "../foundation/semantic-colors.slint";
import { ShellState } from "../state.slint";

component Dot inherits Rectangle {
    in property <float> delay;   // 0..1 phase offset
    width: 8px;
    height: 8px;
    border-radius: 4px;
    background: Theme.text-secondary;
    // Reduce-motion: ~8fps coarse clock instead of display-rate repaints.
    property <float> anim-ms: ShellState.reduce-motion
        ? ShellState.coarse-tick-ms * 1.0
        : animation-tick() / 1ms;
    property <float> phase: Math.mod(root.anim-ms / 900.0 + root.delay, 1.0);
    property <float> tri: 1.0 - Math.abs(root.phase - 0.5) * 2.0;
    opacity: 0.25 + 0.55 * tri;
}

export component LoadingDots inherits Rectangle {
    in property <string> label;

    VerticalLayout {
        alignment: center;
        spacing: 12px;
        HorizontalLayout {
            alignment: center;
            spacing: 8px;
            Dot { delay: 0.0; }
            Dot { delay: 0.18; }
            Dot { delay: 0.36; }
        }
        if root.label != "": Text {
            text: root.label;
            color: Theme.text-muted;
            font-size: 13px;
            horizontal-alignment: center;
        }
    }
}
