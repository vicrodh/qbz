// Album header "more" (⋯) context menu — ported 1:1 from the Tauri
// `AlbumMenu` (src/lib/components/AlbumMenu.svelte) as wired by the album
// detail header. Tauri nests Share/Download as submenus; we render them
// FLAT (the same cosmetic-flat convention as TrackContextMenu) with group
// separators matching Tauri's menu grouping.
//
// Item -> media-action("album", <album-id>, <action>) mapping:
//   Play next               -> "play-next"
//   Add to queue            -> "queue"
//   --
//   Add to playlist         -> "add-to-playlist"
//   Add to Mixtape/Coll.    -> "add-to-mixtape"
//   --
//   Share Qobuz link        -> "share-qobuz"
//   Share Album.link        -> "share-songlink"
//   --
//   Make available offline  -> "cache"      (album NOT fully cached)
//   Refresh offline copy    -> "recache"    (album fully cached)
//
// Tauri's onMakeOffline ("download.makeAvailable") item is NOT passed by
// the album detail header, so it is intentionally absent (1:1). The last
// row swaps Make-available-offline <-> Refresh-offline-copy on
// `fully-cached`, the flat form of Tauri's isAlbumFullyDownloaded submenu
// (which only carries Refresh — no Remove at album level).

import { Theme } from "../foundation/semantic-colors.slint";
import { ContextMenu } from "ContextMenu.slint";
import { ContextMenuItem } from "ContextMenuItem.slint";

export component AlbumContextMenu inherits PopupWindow {
    in property <string> album-id;
    // Every track of the album already has a ready offline copy.
    in property <bool> fully-cached: false;
    // Whether THIS album is on the album blacklist (drives the block toggle).
    in property <bool> is-blocked: false;
    callback media-action(string, string, string);

    width: 224px;
    // 8 rows x 33px + 4 separators x 1px + ContextMenu's 5/5 padding. The
    // offline row swaps label/action on `fully-cached` (count constant); the
    // block row swaps label/action on `is-blocked` (count constant).
    height: 8 * 33px + 4 * 1px + 10px;
    // Default close-policy is close-on-click, which races the row's TouchArea:
    // the popup can dismiss on the press before the item's `clicked` fires, so
    // some rows (e.g. Share Qobuz link) needed a second open+click to register.
    // Close only on outside clicks; each row closes the menu explicitly after
    // its action. Same fix as Sidebar.slint / QueueSidebar.slint.
    close-policy: PopupClosePolicy.close-on-click-outside;

    ContextMenu {
        ContextMenuItem {
            icon: @image-url("../assets/icons/list-plus.svg");
            label: @tr("Play next");
            clicked => {
                root.media-action("album", root.album-id, "play-next");
                root.close();
            }
        }
        ContextMenuItem {
            icon: @image-url("../assets/icons/list-end.svg");
            label: @tr("Add to queue");
            clicked => {
                root.media-action("album", root.album-id, "queue");
                root.close();
            }
        }
        Rectangle { height: 1px; background: Theme.border-subtle; }
        ContextMenuItem {
            icon: @image-url("../assets/icons/list-music.svg");
            label: @tr("Add to playlist");
            clicked => {
                root.media-action("album", root.album-id, "add-to-playlist");
                root.close();
            }
        }
        ContextMenuItem {
            icon: @image-url("../assets/icons/cassette-tape.svg");
            label: @tr("Add to mixtape");
            clicked => {
                root.media-action("album", root.album-id, "add-to-mixtape");
                root.close();
            }
        }
        Rectangle { height: 1px; background: Theme.border-subtle; }
        ContextMenuItem {
            icon: @image-url("../assets/icons/link.svg");
            label: @tr("Share Qobuz link");
            clicked => {
                root.media-action("album", root.album-id, "share-qobuz");
                root.close();
            }
        }
        ContextMenuItem {
            icon: @image-url("../assets/icons/link.svg");
            label: @tr("Share Album.link");
            clicked => {
                root.media-action("album", root.album-id, "share-songlink");
                root.close();
            }
        }
        Rectangle { height: 1px; background: Theme.border-subtle; }
        if !root.fully-cached: ContextMenuItem {
            icon: @image-url("../assets/icons/cloud-download.svg");
            label: @tr("Make available offline");
            clicked => {
                root.media-action("album", root.album-id, "cache");
                root.close();
            }
        }
        if root.fully-cached: ContextMenuItem {
            icon: @image-url("../assets/icons/refresh-cw.svg");
            label: @tr("Refresh offline copy");
            clicked => {
                root.media-action("album", root.album-id, "recache");
                root.close();
            }
        }
        Rectangle { height: 1px; background: Theme.border-subtle; }
        // Album blacklist toggle (surgical, album-id only — independent of the
        // artist blacklist). Main.rs resolves the title/artist/cover from
        // AlbumState (this is the open album) when blocking.
        if !root.is-blocked: ContextMenuItem {
            icon: @image-url("../assets/icons/blind-eye.svg");
            label: @tr("Block this album");
            clicked => {
                root.media-action("album", root.album-id, "block");
                root.close();
            }
        }
        if root.is-blocked: ContextMenuItem {
            icon: @image-url("../assets/icons/blind-eye.svg");
            label: @tr("Unblock album");
            clicked => {
                root.media-action("album", root.album-id, "unblock");
                root.close();
            }
        }
    }
}
