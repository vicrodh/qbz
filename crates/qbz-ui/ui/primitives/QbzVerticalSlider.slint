// Vertical integer slider primitive — dark-themed, draggable. The Y-axis
// mirror of QbzSlider, inverted so the TOP of the track is `maximum` and the
// BOTTOM is `minimum` (the natural orientation for a volume column popping up
// over a button). Like the other primitives it does not own its value: it
// emits `changed(new-value)` and the caller updates the bound state. During a
// drag the thumb follows the pointer directly (local fraction) so it never
// visibly steps between levels.

import { Theme } from "../foundation/semantic-colors.slint";

export component QbzVerticalSlider inherits Rectangle {
    in property <int> minimum: 0;
    in property <int> maximum: 100;
    in property <int> value: 0;
    callback changed(int);

    width: 22px;
    height: 120px;

    // Fraction of the track the current value sits at, clamped to [0, 1].
    property <float> fraction: root.maximum > root.minimum
        ? max(0.0, min(1.0, (root.value - root.minimum) / (root.maximum - root.minimum)))
        : 0.0;
    property <length> thumb-size: 16px;
    // Travel range for the thumb centre (top..bottom of the column).
    property <length> travel: root.height - root.thumb-size;

    // Live drag: while held, the thumb tracks the POINTER directly.
    property <bool> dragging: false;
    property <float> live-fraction: 0.0;
    property <float> shown-fraction: root.dragging ? root.live-fraction : root.fraction;

    // Track (the full vertical rail). HC-only outline keeps the rail visible
    // when accent flattens.
    Rectangle {
        x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
        width: 4px;
        border-radius: 2px;
        background: Theme.surface-elevated;
        border-width: Theme.is-high-contrast ? 1px : 0px;
        border-color: Theme.border-strong;
    }

    // Accent fill — grows UP from the bottom (inverted: more value = taller).
    Rectangle {
        x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
        width: 4px;
        height: root.thumb-size / 2 + root.shown-fraction * root.travel;
        // Pin to the bottom so the fill rises from the floor.
        y: root.height - self.height;
        border-radius: 2px;
        background: Theme.accent;
    }

    // Thumb. fraction 1.0 (max) → top (y == 0); fraction 0.0 (min) → bottom.
    // HC-only border delineates the disc against the filled track.
    Rectangle {
        x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
        y: (1.0 - root.shown-fraction) * root.travel;
        width: root.thumb-size;
        height: root.thumb-size;
        border-radius: root.thumb-size / 2;
        background: Theme.text-primary;
        border-width: Theme.is-high-contrast ? 1px : 0px;
        border-color: Theme.border-strong;
    }

    // Continuous pointer fraction [0,1], inverted axis (no rounding).
    function fraction-from-y(py: length) -> float {
        max(0.0, min(1.0, 1.0 - (py - root.thumb-size / 2) / max(1px, root.travel)))
    }
    // Map a pointer y to the clamped, nearest integer value (closest to position).
    function value-from-y(py: length) -> int {
        root.minimum + round(root.fraction-from-y(py) * (root.maximum - root.minimum))
    }

    ta := TouchArea {
        mouse-cursor: pointer;

        // Jump to the click point on press-down and start the live drag.
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                root.dragging = true;
                root.live-fraction = root.fraction-from-y(self.mouse-y);
                if (root.value-from-y(self.mouse-y) != root.value) {
                    root.changed(root.value-from-y(self.mouse-y));
                }
            }
            if (e.kind == PointerEventKind.up) {
                root.dragging = false;
            }
        }
        // Continuous drag while held — thumb follows the pointer every frame.
        moved => {
            if (root.dragging) {
                root.live-fraction = root.fraction-from-y(self.mouse-y);
                if (root.value-from-y(self.mouse-y) != root.value) {
                    root.changed(root.value-from-y(self.mouse-y));
                }
            }
        }
    }
}
