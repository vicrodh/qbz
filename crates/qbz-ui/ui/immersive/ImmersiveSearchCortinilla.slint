// Immersive search "cortinilla" — the live as-you-type dropdown shown UNDER the
// immersive header search field. It is the immersive twin of the main-header
// Cortinilla (ui/search/Cortinilla.slint): a plain Rectangle overlay (NOT a
// PopupWindow — a PopupWindow grabs the pointer and kills hover on the rows +
// the search field, the documented footgun) mounted INSIDE ImmersiveView, above
// the panels, anchored under the centered search field.
//
// Differences from the main cortinilla (per the design spec
// qbz-nix-docs/specs/2026-06-20-immersive-search-design.md):
//   - GLASS immersive palette (dark translucent panel, white-alpha text) instead
//     of the app Theme tokens.
//   - Sections ONLY (Albums / Artists / Playlists). NO top-result hero, NO
//     "View more" affordance (immersive has no results page to navigate to —
//     selecting acts on PLAYBACK and stays in immersive).
//   - Reads ImmersiveState.search-* (NOT SearchState).
//   - Anchored under the immersive header field; height-capped so the panel
//     never covers the immersive compact player bar at the bottom.
//
// `parent` is never used in any root binding here (Slint footgun: `parent` in a
// component definition's ROOT binding is illegal); all dims come from in-
// properties or explicit values. No `opacity` on any component root (it corrupts
// absolute-position anchoring). 56px is the fixed row height (mirrors the main
// cortinilla; used for the keyboard scroll-into-view math).

import { Typography } from "../foundation/typography.slint";
import { ImmersiveState, ImmersiveSearchActions, CortinillaRow, CortinillaSection, ShellState } from "../state.slint";
import { ListScrollbar } from "../primitives/ListScrollbar.slint";

// A single immersive-tinted result row — 40x40 thumbnail (circle for artists,
// tile otherwise) + title / subtitle, with a hover highlight and a keyboard
// "active" accent bar. Glass palette. `parent` is never used in this root's
// bindings (dims come from the layout / explicit values).
component ImmersiveResultRow inherits Rectangle {
    in property <CortinillaRow> item;
    // The flat index currently highlighted by the keyboard (-1 = none). Hover is
    // PURELY visual — it deliberately does NOT write search-selected-index, so a
    // stray hover can never hijack the keyboard selection that Enter activates
    // (same lesson as the main cortinilla).
    in property <int> selected-index;
    // The keyboard accent color (immersive lyrics accent by default).
    in property <color> accent: #3fd9c8;
    callback clicked(int /* flat-index */);

    property <bool> active: root.selected-index == root.item.flat-index;

    height: 56px;
    border-radius: 8px;
    // Active (keyboard) = brighter; plain hover = subtle glass wash.
    background: root.active ? #ffffff26 : (ta.has-hover ? #ffffff14 : transparent);

    // Accent bar marking the keyboard-active row — clearly distinct from a plain
    // mouse hover so the arrow-key selection is unmistakable.
    if root.active: Rectangle {
        x: 0;
        y: 4px;
        width: 3px;
        height: root.height - 8px;
        border-radius: 2px;
        background: root.accent;
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 12px;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 40px;
                height: 40px;
                // Artists read better as a circle; everything else is a tile.
                border-radius: root.item.kind == "artist" ? 20px : 4px;
                background: #ffffff14;
                clip: true;
                Image {
                    width: 100%;
                    height: 100%;
                    source: root.item.artwork;
                    image-fit: cover;
                }
            }
        }

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;
            Text {
                text: root.item.title;
                color: #ffffffcc;
                font-size: Typography.link;
                font-weight: Typography.medium;
                overflow: elide;
            }
            Text {
                text: root.item.subtitle;
                color: #ffffff80;
                font-size: 12px;
                overflow: elide;
            }
        }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked(root.item.flat-index);
        }
    }
}

// A placeholder "skeleton" row shown WHILE results load — a pulsing thumbnail box
// + two text bars. Replaces a cached instant-paint so results never "jump".
// Math.sin takes an ANGLE in Slint, so scale ms -> degrees. Under reduce-motion
// the ms source is the shared ~8fps coarse clock instead of animation-tick.
component ImmersiveSkeletonRow inherits Rectangle {
    height: 56px;
    property <float> anim-ms: ShellState.reduce-motion
        ? ShellState.coarse-tick-ms * 1.0
        : animation-tick() / 1ms;
    property <float> pulse: 0.20 + 0.12 * Math.sin(root.anim-ms * 0.25deg);

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 12px;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 40px;
                height: 40px;
                border-radius: 4px;
                background: #ffffffff;
                opacity: root.pulse;
            }
        }

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 8px;
            HorizontalLayout {
                Rectangle {
                    width: 150px;
                    height: 11px;
                    border-radius: 3px;
                    background: #ffffffff;
                    opacity: root.pulse;
                }
                Rectangle { horizontal-stretch: 1; }
            }
            HorizontalLayout {
                Rectangle {
                    width: 96px;
                    height: 9px;
                    border-radius: 3px;
                    background: #ffffffff;
                    opacity: root.pulse;
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }
    }
}

export component ImmersiveSearchCortinilla inherits Rectangle {
    // Window dimensions, passed in by the host (ImmersiveView) so this root never
    // touches `parent` (illegal in a root binding). Used to center the panel and
    // to compute the height cap against the player bar.
    in property <length> window-width: 0px;
    in property <length> window-height: 0px;
    // The TOP of the centered search field (header-band y + field height + a small
    // gap), used to anchor the panel just below the field. The host passes the
    // resolved value so the panel tracks the field if the header geometry changes.
    in property <length> anchor-y: 58px;
    // The immersive player bar's reserved bottom band (bar height + its bottom
    // inset + a breathing gap). The panel's bottom edge stays ABOVE this.
    in property <length> bottom-reserved: 138px;
    // Keyboard accent (lyrics accent from the host so it matches the atmosphere).
    in property <color> accent: #3fd9c8;

    // Only render (and only consume events) when the search is open AND the live
    // query is long enough to have meaningful results. character-count mirrors the
    // controller's >= 2 gate so a 1-char query never flashes a half-empty panel.
    visible: ImmersiveState.search-open
        && ImmersiveState.search-query.character-count >= 2;

    // Panel geometry. Fixed width (no parent/sibling width references that could
    // form a binding loop); centered under the header field via window-width math.
    property <length> panel-width: 380px;

    // Click-outside scrims — ANY click outside the cortinilla panel dismisses it.
    // Transparent TouchAreas tile the whole window EXCEPT the panel (declared
    // later → renders on top, keeps its own clicks) and the centered search field
    // (the header strip's central gap), which must stay focusable / typeable. The
    // header band sits in [anchor-y - field-height .. anchor-y]; leave that whole
    // band un-scrimmed across the field's horizontal span so the field + its
    // controls stay clickable.
    //   field horizontal span (centered, same width math as the panel anchor):
    property <length> field-width: Math.min(root.window-width - 48px, 420px);
    property <length> field-left: (root.window-width - root.field-width) / 2;
    //   the header band's vertical extent (field is 36px tall, gap is 6px):
    property <length> band-bottom: root.anchor-y - 6px;

    //   1) everything BELOW the header band (panels, player bar region)
    if root.visible: TouchArea {
        x: 0;
        y: root.band-bottom;
        width: root.window-width;
        height: root.window-height - self.y;
        clicked => { ImmersiveSearchActions.dismiss(); }
    }
    //   2) header band, LEFT of the search field
    if root.visible: TouchArea {
        x: 0;
        y: 0;
        width: root.field-left;
        height: root.band-bottom;
        clicked => { ImmersiveSearchActions.dismiss(); }
    }
    //   3) header band, RIGHT of the search field
    if root.visible: TouchArea {
        x: root.field-left + root.field-width;
        y: 0;
        width: root.window-width - self.x;
        height: root.band-bottom;
        clicked => { ImmersiveSearchActions.dismiss(); }
    }

    // The panel itself. Anchored under the centered search field. Its total height
    // (scrolling body) is capped so the bottom edge stays ABOVE the player bar —
    // the cortinilla must never cover it. A tall result set scrolls inside the
    // Flickable; a short one collapses.
    if root.visible: panel := Rectangle {
        // Cap the scrolling body so the WHOLE panel ends above the player bar.
        // Driven only by the passed-in window-height + the reserved bottom band +
        // the panel padding (never a sibling's geometry → no binding-loop / cycle).
        // anchor-y = panel top; bottom-reserved = the player-bar band; 12px = the
        // panel-box VLayout top/bottom padding.
        property <length> scroll-cap:
            root.window-height - root.anchor-y - root.bottom-reserved - 12px;

        // Keyboard scroll-into-view. The controller sets search-scroll-y to the
        // content-top of the selected row on each arrow move; mirror it and, on
        // change, nudge the Flickable so that row is visible. Imperative
        // viewport-y writes in a `changed` (NOT a binding) so this never loops with
        // the scrollbar's two-way viewport-y binding. Flickable viewport-y is <= 0
        // (content scrolled up), so the visible band is
        // [-viewport-y, -viewport-y + height]; 56px is the row height.
        property <length> sel-scroll-y: ImmersiveState.search-scroll-y;
        changed sel-scroll-y => {
            if (self.sel-scroll-y < -body-flick.viewport-y) {
                body-flick.viewport-y = -self.sel-scroll-y;
            } else if (self.sel-scroll-y + 56px > -body-flick.viewport-y + body-flick.height) {
                body-flick.viewport-y = -(self.sel-scroll-y + 56px - body-flick.height);
            }
        }

        x: (root.window-width - root.panel-width) / 2;
        y: root.anchor-y;
        width: root.panel-width;
        height: panel-box.preferred-height;

        panel-box := Rectangle {
            // Immersive glass palette.
            background: #00000094;
            border-radius: 16px;
            border-width: 1px;
            border-color: #ffffff1a;
            drop-shadow-blur: 32px;
            drop-shadow-color: #00000066;
            drop-shadow-offset-y: 8px;
            // Keeps the pointer "inside" the panel so the scrim click does not fall
            // through, and gives the rows a stable hover surface.
            clip: true;

            VerticalLayout {
                padding-top: 6px;
                padding-bottom: 6px;

                // --- Scrolling result body ----------------------------------
                // Skeleton (while loading) / no-results / sections, all inside a
                // Flickable so a tall set stays reachable. The body height is its
                // content height clamped to `scroll-cap`. A short body collapses;
                // a tall body scrolls. viewport-height feeds the sibling scrollbar.
                Rectangle {
                    height: Math.min(scroll-content.preferred-height, panel.scroll-cap);

                    body-flick := Flickable {
                        width: 100%;
                        height: 100%;
                        viewport-width: self.width;
                        viewport-height: scroll-content.preferred-height;

                        scroll-content := VerticalLayout {
                            width: parent.width;
                            alignment: start;

                            // --- Loading skeleton -------------------------------
                            if ImmersiveState.search-loading: VerticalLayout {
                                padding-top: 4px;
                                ImmersiveSkeletonRow { }
                                ImmersiveSkeletonRow { }
                                ImmersiveSkeletonRow { }
                                ImmersiveSkeletonRow { }
                            }

                            // --- Loaded content ---------------------------------
                            if !ImmersiveState.search-loading: VerticalLayout {
                                alignment: start;

                                // No results: explicit empty-state line.
                                if ImmersiveState.search-sections.length == 0: Rectangle {
                                    height: 28px;
                                    HorizontalLayout {
                                        padding-left: 14px;
                                        padding-right: 14px;
                                        Text {
                                            text: @tr("No results for") + " “" + ImmersiveState.search-query + "”";
                                            color: #ffffff80;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }

                                // Result sections (Albums / Artists / Playlists).
                                // No "View more" — immersive has no results page.
                                for section[si] in ImmersiveState.search-sections: VerticalLayout {
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    padding-top: 4px;

                                    // Section header — title only (immersive-muted).
                                    HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        height: 24px;
                                        Text {
                                            text: section.title;
                                            color: #ffffff80;
                                            font-size: 11px;
                                            font-weight: Typography.semibold;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                    }

                                    // Section rows.
                                    for entry[ri] in section.rows: ImmersiveResultRow {
                                        item: entry;
                                        selected-index: ImmersiveState.search-selected-index;
                                        accent: root.accent;
                                        clicked(fi) => {
                                            ImmersiveSearchActions.row-clicked(fi);
                                        }
                                        // Hover is purely visual (the row's own
                                        // has-hover highlight). It deliberately does
                                        // NOT write search-selected-index, so moving
                                        // the mouse never hijacks the keyboard
                                        // selection that Enter activates.
                                    }
                                }
                            }
                        }
                    }

                    // Auto-hiding scrollbar in its own gutter, shown only when the
                    // body overflows (ListScrollbar self-hides at max-scroll <= 0).
                    ListScrollbar {
                        x: parent.width - self.width;
                        width: 10px;
                        height: 100%;
                        auto-hide: true;
                        viewport-height: body-flick.viewport-height;
                        visible-height: body-flick.height;
                        viewport-y <=> body-flick.viewport-y;
                    }
                }
            }
        }
    }
}
