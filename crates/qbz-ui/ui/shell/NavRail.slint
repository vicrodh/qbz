// Bottom NavRail — small-panel touch navigation (2.0.2 frente #3, Axis B).
//
// Icon+label tiles (Radius.sm rectangles, NO pills — ADR-008) replacing the
// desktop Sidebar, driving the SAME NavState routes. Tiles are positioned
// MANUALLY (absolute x + explicit width from root.width) — every layout-based
// attempt left them collapsed to icon width on the left; absolute positioning
// takes the width straight from the rail (which KioskShell stretches to the
// panel).
import { Theme } from "../foundation/semantic-colors.slint";
import { Radius } from "../foundation/radius.slint";
import { NavState, ContentView, ImmersiveState, MyQbzBrandingState } from "../state.slint";

component NavTile inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> active;
    callback clicked;

    border-radius: Radius.sm;
    background: root.active
        ? Theme.accent.with-alpha(0.12)
        : ta.has-hover ? Theme.alpha-6 : transparent;
    border-width: root.active ? 1px : 0px;
    border-color: Theme.accent.with-alpha(0.30);

    VerticalLayout {
        alignment: center;
        spacing: 5px;
        // A fixed-size child does not center itself horizontally in a
        // VerticalLayout — wrap the icon in a full-width centering row.
        HorizontalLayout {
            alignment: center;
            Image {
                source: root.icon;
                colorize: root.active ? Theme.accent : Theme.text-muted;
                width: 24px;
                height: 24px;
            }
        }
        Text {
            text: root.label;
            color: root.active ? Theme.accent : Theme.text-muted;
            font-size: 11.5px;
            font-weight: 600;
            horizontal-alignment: center;
            overflow: elide;
        }
    }

    ta := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component NavRail inherits Rectangle {
    callback discover();
    callback library();
    callback local-library();
    callback myqbz();
    callback playing();
    callback visualizer();
    callback menu();

    background: Theme.surface-main;

    // 7 tiles, 8px outer padding, 6px gaps (6 gaps). Search is intentionally
    // absent — the back-bar carries a persistent search field, so a footer
    // Search tile is redundant.
    property <length> tw: (root.width - 16px - 6 * 6px) / 7;
    property <length> th: root.height - 18px;

    Rectangle {
        x: 0;
        y: 0;
        width: root.width;
        height: 1px;
        background: Theme.border-subtle;
    }

    NavTile {
        x: 8px + 0 * (root.tw + 6px);
        y: 9px;
        width: root.tw;
        height: root.th;
        icon: @image-url("../assets/icons/compass.svg");
        label: @tr("Discover");
        active: NavState.view == ContentView.home;
        clicked => {
            root.discover();
        }
    }
    NavTile {
        x: 8px + 1 * (root.tw + 6px);
        y: 9px;
        width: root.tw;
        height: root.th;
        icon: @image-url("../assets/icons/library-big.svg");
        label: @tr("Library");
        active: NavState.view == ContentView.favorites;
        clicked => {
            root.library();
        }
    }
    NavTile {
        x: 8px + 2 * (root.tw + 6px);
        y: 9px;
        width: root.tw;
        height: root.th;
        icon: @image-url("../assets/icons/hard-drive.svg");
        label: @tr("Local Library");
        active: NavState.view == ContentView.local-library || NavState.view == ContentView.local-album;
        clicked => {
            root.local-library();
        }
    }
    NavTile {
        x: 8px + 3 * (root.tw + 6px);
        y: 9px;
        width: root.tw;
        height: root.th;
        icon: @image-url("../assets/icons/music-library-2.svg");
        label: MyQbzBrandingState.label;
        active: NavState.view == ContentView.mixtapes
            || NavState.view == ContentView.collections
            || NavState.view == ContentView.mixtape-detail;
        clicked => {
            root.myqbz();
        }
    }
    NavTile {
        x: 8px + 4 * (root.tw + 6px);
        y: 9px;
        width: root.tw;
        height: root.th;
        icon: @image-url("../assets/icons/play-fill.svg");
        label: @tr("Now Playing");
        active: NavState.view == ContentView.now-playing;
        clicked => {
            root.playing();
        }
    }
    NavTile {
        x: 8px + 5 * (root.tw + 6px);
        y: 9px;
        width: root.tw;
        height: root.th;
        icon: @image-url("../assets/icons/sliders-horizontal.svg");
        label: @tr("Visualizer");
        active: false;
        clicked => {
            root.visualizer();
        }
    }
    NavTile {
        x: 8px + 6 * (root.tw + 6px);
        y: 9px;
        width: root.tw;
        height: root.th;
        icon: @image-url("../assets/icons/settings.svg");
        label: @tr("Settings");
        active: NavState.view == ContentView.settings;
        clicked => {
            root.menu();
        }
    }
}
