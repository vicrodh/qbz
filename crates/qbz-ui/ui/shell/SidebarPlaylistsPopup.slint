// Closed-sidebar playlists flyout. With the sidebar fully closed there is no
// playlist list anywhere, so a header button (CompactPlaylistsBtn) opens this
// popup. A search header filters the entries as you type (same Rust-side
// filter as the sidebar — see the header note), it lists SidebarState's
// entries (folders + playlists, the same flat tree the sidebar shows), six
// rows visible with the rest scrolling, and a footer with Import + Manage
// playlists. Rendered at the AppShell level because the header clips its
// overflow.

import { Theme } from "../foundation/semantic-colors.slint";
import { Radius } from "../foundation/radius.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";
import { ListScrollbar } from "../primitives/ListScrollbar.slint";
import { LineEdit } from "std-widgets.slint";
import { SidebarPlaylistsPopupState, SidebarState, SidebarActions, SidebarEntry, OfflineState , UiFocusState } from "../state.slint";

// One entry row — a folder (bold, toggles expand) or a playlist (opens it).
component PpRow inherits Rectangle {
    in property <SidebarEntry> entry;
    property <bool> is-folder: root.entry.kind == "folder";
    height: 32px;
    border-radius: 5px;
    background: ta.has-hover ? Theme.surface-hover : transparent;
    HorizontalLayout {
        // Nested playlists indent under their folder, matching the sidebar.
        padding-left: root.entry.indent ? 26px : 12px;
        padding-right: 12px;
        spacing: 8px;
        VerticalLayout {
            alignment: center;
            QbzIcon {
                source: root.is-folder
                    ? (root.entry.expanded
                        ? @image-url("../assets/icons/folder-open.svg")
                        : @image-url("../assets/icons/folder.svg"))
                    : @image-url("../assets/icons/list-music.svg");
                width: 14px;
                height: 14px;
                tint: root.is-folder ? Theme.accent : Theme.text-muted;
            }
        }
        Text {
            text: root.entry.name;
            color: root.is-folder ? Theme.text-primary : Theme.text-secondary;
            font-size: 13px;
            font-weight: root.is-folder ? 600 : 400;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        // Folder playlist count, right-aligned (matches the sidebar hover count).
        if root.is-folder && root.entry.count > 0: Text {
            text: root.entry.count;
            color: Theme.text-muted;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            if (root.is-folder) {
                // Expand/collapse in place — re-renders the list, like the sidebar.
                SidebarActions.toggle-folder(root.entry.id);
            } else {
                SidebarActions.open-playlist(root.entry.id);
                SidebarPlaylistsPopupState.open = false;
                // Clear the shared filter so it doesn't silently scope the
                // expanded sidebar's list later (search-query is global).
                SidebarState.search-query = "";
                SidebarActions.search-changed("");
            }
        }
    }
}

export component SidebarPlaylistsPopup inherits Rectangle {
    visible: SidebarPlaylistsPopupState.open;

    property <length> row-h: 32px;
    property <int> visible-rows: Math.min(SidebarState.entries.length, 6);
    property <length> list-h: Math.max(root.row-h, root.visible-rows * root.row-h);

    // Scrim — a click anywhere outside the panel closes the popup.
    if SidebarPlaylistsPopupState.open: TouchArea {
        clicked => {
            SidebarPlaylistsPopupState.open = false;
            SidebarState.search-query = "";
            SidebarActions.search-changed("");
        }
    }

    if SidebarPlaylistsPopupState.open: Rectangle {
        x: SidebarPlaylistsPopupState.anchor-x;
        y: SidebarPlaylistsPopupState.anchor-y;
        width: 248px;
        // search(34) + list + divider(1) + import(40) + manage(40) + paddings(8).
        height: 34px + root.list-h + 1px + 40px + 40px + 8px;

        Rectangle {
            background: Theme.surface-main;
            border-radius: Radius.sm;
            border-width: 1px;
            border-color: Theme.border-muted;
            drop-shadow-blur: 24px;
            drop-shadow-color: Theme.card-shadow;
            drop-shadow-offset-y: 6px;

            // Swallow clicks so the scrim doesn't close while interacting.
            TouchArea { }

            VerticalLayout {
                padding-top: 4px;
                padding-bottom: 4px;

                // Search header — filters the entries as you type. The filter
                // is shared with the sidebar (applied Rust-side in
                // crate::sidebar via search-changed, recursively across
                // folders), so `SidebarState.entries` below is already the
                // filtered set. Always visible (this flyout is search-first,
                // unlike the sidebar's toggle). Auto-focus is deferred via a
                // 1ms Timer for the same reason the sidebar does it: focusing
                // during the mount/layout pass panics with "Recursion
                // detected" (i-slint-core properties.rs).
                Rectangle {
                    height: 34px;
                    pp-search := LineEdit {
                        x: 8px;
                        y: (parent.height - self.height) / 2;
                        width: parent.width - 16px;
                        height: 26px;
                        placeholder-text: @tr("Search playlists");
                        // Hotkey-guard probe: a use-site `changed has-focus` on a std-widgets
                        // input never fires (has-focus is an alias into the inner TextInput),
                        // so observe it through a local property instead (#619).
                        property <bool> guard-focused: self.has-focus;
                        changed guard-focused => { UiFocusState.text-input-focused = self.guard-focused; }
                        text <=> SidebarState.search-query;
                        edited => {
                            SidebarActions.search-changed(self.text);
                        }
                    }
                    pp-focus-timer := Timer {
                        interval: 1ms;
                        running: true;
                        triggered => {
                            pp-search.focus();
                            self.running = false;
                        }
                    }
                }

                // Entries — capped at six rows; scrolls beyond. The Flickable is
                // unconditional (an empty list just renders no rows) so the
                // sibling ListScrollbar can reference `pp-flick` — an id declared
                // inside an `if` is not visible to a sibling `if`.
                Rectangle {
                    height: root.list-h;
                    pp-flick := Flickable {
                        width: 100%;
                        height: 100%;
                        viewport-width: self.width;
                        viewport-height: SidebarState.entries.length * root.row-h;
                        VerticalLayout {
                            width: parent.width;
                            alignment: start;
                            for entry in SidebarState.entries: PpRow {
                                entry: entry;
                            }
                        }
                    }
                    if SidebarState.entries.length > 6: ListScrollbar {
                        x: parent.width - self.width;
                        width: 10px;
                        height: 100%;
                        viewport-height: pp-flick.viewport-height;
                        visible-height: pp-flick.height;
                        viewport-y <=> pp-flick.viewport-y;
                    }
                    if SidebarState.entries.length == 0: Text {
                        x: 12px;
                        y: 8px;
                        text: @tr("No playlists yet.");
                        color: Theme.text-muted;
                        font-size: 12px;
                    }
                }

                Rectangle {
                    height: 1px;
                    background: Theme.border-subtle;
                }

                // Import — open the importer modal (mirrors the sidebar "..."
                // menu's Import item). Dimmed + inert while offline, exactly
                // like the sidebar; the modal's own offline banner is the
                // second layer.
                Rectangle {
                    height: 40px;
                    border-radius: 5px;
                    background: (!OfflineState.offline && import-ta.has-hover) ? Theme.surface-hover : transparent;
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;
                        VerticalLayout {
                            alignment: center;
                            QbzIcon {
                                source: @image-url("../assets/icons/import.svg");
                                width: 15px;
                                height: 15px;
                                tint: OfflineState.offline ? Theme.text-muted : Theme.text-secondary;
                            }
                        }
                        Text {
                            text: @tr("Import");
                            color: OfflineState.offline ? Theme.text-muted : Theme.text-secondary;
                            font-size: 13px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                    import-ta := TouchArea {
                        mouse-cursor: OfflineState.offline ? default : pointer;
                        clicked => {
                            if (!OfflineState.offline) {
                                SidebarActions.import-playlist();
                                SidebarPlaylistsPopupState.open = false;
                                SidebarState.search-query = "";
                                SidebarActions.search-changed("");
                            }
                        }
                    }
                }

                // Footer — always visible link to the Playlist Manager.
                Rectangle {
                    height: 40px;
                    border-radius: 5px;
                    background: footer-ta.has-hover ? Theme.surface-hover : transparent;
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;
                        VerticalLayout {
                            alignment: center;
                            QbzIcon {
                                source: @image-url("../assets/icons/library-big.svg");
                                width: 15px;
                                height: 15px;
                                tint: Theme.text-secondary;
                            }
                        }
                        Text {
                            text: @tr("Manage playlists");
                            color: Theme.text-secondary;
                            font-size: 13px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                    footer-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            SidebarActions.manage-playlists();
                            SidebarPlaylistsPopupState.open = false;
                            SidebarState.search-query = "";
                            SidebarActions.search-changed("");
                        }
                    }
                }
            }
        }
    }
}
