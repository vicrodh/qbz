// Search "cortinilla" — the live as-you-type dropdown shown under the header
// search box. It is the in-window overlay equivalent of HeaderMenuOverlay:
// a plain Rectangle mounted as a LAST child of AppShell, NOT a PopupWindow.
//
// Why not a PopupWindow: a PopupWindow grabs the pointer while open, which
// kills hover on the rows and on the header search box itself (the exact
// footgun documented for the nav-tab menus). A plain Rectangle overlay does
// not grab the pointer, so the search box stays focused/typeable and the
// rows stay hoverable while results stream in.
//
// Layout (top -> bottom):
//   - a slim pinned strip with an "Enter" hint floating right (runs the full
//     Search > All; the redundant "Search for <query>" text was dropped);
//   - while loading: a skeleton of placeholder rows (no cached instant-paint,
//     so results never "jump" from a cached to a fresh state);
//   - loaded: the promoted top-result row (flat-index 0), then the labelled
//     sections, each a header (+ "View more") and its rows. Each row carries
//     its own controller-assigned `flat-index`, used for click dispatch and the
//     hover highlight (highlighted when flat-index == selected-index).
//
// The panel is anchored under the absolutely-centered header search box and is
// height-capped so it NEVER covers the now-playing bar (npb-mode aware). Any
// click outside the panel (content, sidebar, player, or the header strip beside
// the search box) dismisses it; a page change dismisses it too (AppShell).

import { Theme } from "../foundation/semantic-colors.slint";
import { Radius } from "../foundation/radius.slint";
import { Layout } from "../foundation/layout.slint";
import { Typography } from "../foundation/typography.slint";
import { SearchState, SearchActions, CortinillaRow, CortinillaSection, ShellState } from "../state.slint";
import { ListScrollbar } from "../primitives/ListScrollbar.slint";

// A single SlimCard-style result row inside the cortinilla — 40x40 thumbnail
// plus a title / subtitle, with a hover/keyboard highlight. `parent` is never
// used in this root's bindings (dims come from the layout / explicit values).
component CortinillaResultRow inherits Rectangle {
    in property <CortinillaRow> item;
    // The flat index currently highlighted by hover or keyboard (-1 = none).
    in property <int> selected-index;
    callback clicked(int /* flat-index */);
    // Reports hover so the host can drive the highlight off the same flat-index
    // space (hovering a row "selects" it).
    callback hover-changed(int /* flat-index */, bool);

    property <bool> active: root.selected-index == root.item.flat-index;

    height: 56px;
    border-radius: Radius.sm;
    background: (root.active || ta.has-hover) ? Theme.surface-hover : transparent;

    // Accent bar marking the keyboard-active row — clearly distinct from a plain
    // mouse hover so the arrow-key selection is unmistakable.
    if root.active: Rectangle {
        x: 0;
        y: 4px;
        width: 3px;
        height: root.height - 8px;
        border-radius: 2px;
        background: Theme.accent;
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 12px;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 40px;
                height: 40px;
                // Artists read better as a circle; everything else is a tile.
                border-radius: root.item.kind == "artist" ? 20px : 4px;
                background: Theme.surface-elevated;
                clip: true;
                Image {
                    width: 100%;
                    height: 100%;
                    source: root.item.artwork;
                    image-fit: cover;
                }
            }
        }

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;
            Text {
                text: root.item.title;
                color: Theme.text-primary;
                font-size: Typography.link;
                font-weight: Typography.medium;
                overflow: elide;
            }
            Text {
                text: root.item.subtitle;
                color: Theme.text-muted;
                font-size: 12px;
                overflow: elide;
            }
        }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked(root.item.flat-index);
        }
        changed has-hover => {
            root.hover-changed(root.item.flat-index, self.has-hover);
        }
    }
}

// A placeholder "skeleton" row shown WHILE results load — a pulsing thumbnail
// box + two text bars. Replaces the cached instant-paint so results never
// "jump" from a cached to a fresh state; the skeleton holds the space and a
// single real paint lands once the query settles.
component CortinillaSkeletonRow inherits Rectangle {
    height: 56px;
    // Subtle continuous pulse. Opacity oscillates ~0.16..0.48. Math.sin takes
    // an ANGLE in Slint, so scale ms -> degrees (0.25deg/ms ≈ a 1.4 s period).
    // Under reduce-motion the ms source is the shared ~8fps coarse clock (a
    // property that CHANGES, unlike the static-Timer gotcha) instead of the
    // display-rate animation-tick — this pulse was the main cost of opening
    // the cortinilla on weak GPUs (every frame = full-window repaint).
    property <float> anim-ms: ShellState.reduce-motion
        ? ShellState.coarse-tick-ms * 1.0
        : animation-tick() / 1ms;
    property <float> pulse: 0.32 + 0.16 * Math.sin(root.anim-ms * 0.25deg);

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 12px;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 40px;
                height: 40px;
                border-radius: 4px;
                background: Theme.surface-elevated;
                opacity: root.pulse;
            }
        }

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 8px;
            HorizontalLayout {
                Rectangle {
                    width: 150px;
                    height: 11px;
                    border-radius: 3px;
                    background: Theme.surface-elevated;
                    opacity: root.pulse;
                }
                Rectangle { horizontal-stretch: 1; }
            }
            HorizontalLayout {
                Rectangle {
                    width: 96px;
                    height: 9px;
                    border-radius: 3px;
                    background: Theme.surface-elevated;
                    opacity: root.pulse;
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }
    }
}

export component Cortinilla inherits Rectangle {
    // Bubbled up to AppShell for the controller to act on (mirrors how
    // HeaderMenuOverlay bubbles `navigate`). These forward straight to the
    // SearchActions callbacks; AppShell wires them to Rust.
    callback row-clicked(int /* flat-index */);
    callback view-more(string /* kind */);
    callback search-all();
    callback dismiss();

    // Only render (and only consume events) when the cortinilla is open AND the
    // live query is long enough to have meaningful results. character-count
    // mirrors the controller's >= 2 gate so a 1-char query never flashes a
    // half-empty panel.
    visible: SearchState.cortinilla-open
        && SearchState.cortinilla-query.character-count >= 2;

    // Panel geometry. Width is fixed (no parent/sibling width references that
    // could form a binding loop); the panel is centered under the header
    // search box via root.width arithmetic.
    property <length> panel-width: 320px;

    // The centered header search box width (mirrors HeaderBar's responsive
    // `search-width`), used to leave a click-through gap for the box in the
    // header-strip scrims below.
    property <length> search-box-width:
        (root.width < 960px ? 179px : 256px) - (ShellState.nav-in-sidebar ? 0px : 60px);

    // --- Idle auto-close ---------------------------------------------------
    // Dismiss the dropdown after ~4.5 s of inactivity: no pointer over the
    // panel and no search activity. `panel-hovered` mirrors the panel's
    // wrapper TouchArea (the panel lives in an `if` subtree; a Timer in there
    // cannot be restart()ed — 1.16 compiler panic — so the timer lives here).
    property <bool> panel-hovered: false;
    // The mirror can go stale when the panel unmounts while hovered (its
    // `changed has-hover` never fires false) — reset it on every open/close.
    changed visible => { root.panel-hovered = false; }
    idle-close := Timer {
        interval: 4500ms;
        running: root.visible && !root.panel-hovered;
        triggered => { root.dismiss(); }
    }
    // Activity probes — a keystroke (live query change) or an arrow-key
    // selection move restarts the countdown. Guarded: while the panel is
    // hovered the timer is paused by its `running` binding, and an imperative
    // restart() would wrongly resume it.
    property <string> idle-query-probe: SearchState.cortinilla-query;
    changed idle-query-probe => {
        if (root.visible && !root.panel-hovered) { idle-close.restart(); }
    }
    property <int> idle-sel-probe: SearchState.selected-index;
    changed idle-sel-probe => {
        if (root.visible && !root.panel-hovered) { idle-close.restart(); }
    }

    // Click-outside scrims — ANY click outside the cortinilla panel dismisses
    // it. Three transparent TouchAreas tile the whole window EXCEPT (a) the
    // panel (declared later, so it renders on top and keeps its own clicks) and
    // (b) the header search box (the central gap), which must stay focusable /
    // typeable. A page change also dismisses it (AppShell `changed tracked-view`).
    //   1) everything BELOW the header (content, sidebar, player bar)
    if root.visible: TouchArea {
        x: 0;
        y: Layout.header-height;
        width: root.width;
        height: root.height - self.y;
        clicked => { root.dismiss(); }
    }
    //   2) header strip LEFT of the search box
    if root.visible: TouchArea {
        x: 0;
        y: 0;
        width: (root.width - root.search-box-width) / 2;
        height: Layout.header-height;
        clicked => { root.dismiss(); }
    }
    //   3) header strip RIGHT of the search box
    if root.visible: TouchArea {
        x: (root.width + root.search-box-width) / 2;
        y: 0;
        width: root.width - self.x;
        height: Layout.header-height;
        clicked => { root.dismiss(); }
    }

    // The panel itself. Anchored under the centered search box. Its TOTAL height
    // (pinned Enter strip + divider + scrolling body) is capped so the bottom
    // edge stays ABOVE the now-playing bar — the cortinilla must never cover the
    // NPB. A tall result set scrolls inside the Flickable; a short one collapses.
    if root.visible: panel := Rectangle {
        // Cap the scrolling body so the WHOLE panel ends above the NPB. The bar
        // height is npb-mode aware (SAME breakpoint as the NPB / AppShell content
        // area), so the cap responds per mode. 12px = the panel-box VLayout's
        // top/bottom padding (there is no pinned strip any more). Driven only by
        // `root.height` + ShellState (never a sibling's geometry) so no
        // binding-loop / cycle.
        property <length> scroll-cap:
            root.height - Layout.header-height - 6px
            - (ShellState.npb-mode == 2 ? Layout.header-height : Layout.player-bar-height)
            - 16px - 12px;

        // Keyboard scroll-into-view. The controller sets cortinilla-scroll-y to
        // the content-top of the selected row on each arrow move; mirror it and,
        // on change, nudge the Flickable so that row is visible. Imperative
        // viewport-y writes in a `changed` (NOT a binding) so this never loops
        // with the scrollbar's two-way viewport-y binding. Flickable viewport-y
        // is <= 0 (content scrolled up), so the visible content band is
        // [-viewport-y, -viewport-y + height]; 56px is the row height.
        property <length> sel-scroll-y: SearchState.cortinilla-scroll-y;
        changed sel-scroll-y => {
            if (self.sel-scroll-y < -body-flick.viewport-y) {
                body-flick.viewport-y = -self.sel-scroll-y;
            } else if (self.sel-scroll-y + 56px > -body-flick.viewport-y + body-flick.height) {
                body-flick.viewport-y = -(self.sel-scroll-y + 56px - body-flick.height);
            }
        }

        x: (root.width - root.panel-width) / 2;
        y: Layout.header-height + 6px;
        width: root.panel-width;
        height: panel-box.preferred-height;


        // Hover surface for the idle-close pause (see the root-level Timer —
        // it must live OUTSIDE this `if` subtree: `Timer.restart()` on a timer
        // inside a conditional sub-component panics the 1.16 Slint compiler).
        // `hover-ta` is an ANCESTOR of every row/button TouchArea, and Slint
        // sets has-hover on ancestors too (input_event_filter_before_children),
        // so hovering any child counts. Clicks on rows/buttons are handled by
        // their own (descendant) TouchAreas first; wheel events pass through
        // to the Flickable.
        hover-ta := TouchArea {
            changed has-hover => { root.panel-hovered = self.has-hover; }
            panel-box := Rectangle {
                background: Theme.surface-main;
                border-radius: Radius.sm;
                border-width: 1px;
                border-color: Theme.border-muted;
                drop-shadow-blur: 24px;
                drop-shadow-color: Theme.card-shadow;
                drop-shadow-offset-y: 6px;
                // Keeps the pointer "inside" the panel so the scrim click does not
                // fall through, and gives the rows a stable hover surface.
                clip: true;

                VerticalLayout {
                    padding-top: 6px;
                    padding-bottom: 6px;

                    // No pinned "Full results" row here — the Enter affordance lives
                    // in the header search box (right edge, opposite the magnifier)
                    // while the cortinilla is open. The result body is the whole panel.

                    // --- Scrolling result body ------------------------------------
                    // Skeleton (while loading) / no-results / top-result / sections,
                    // all inside a Flickable so a tall set stays reachable. The body
                    // height is its content height clamped to `scroll-cap`. A short
                    // body collapses; a tall body scrolls. viewport-height feeds the
                    // sibling scrollbar.
                    Rectangle {
                        height: Math.min(scroll-content.preferred-height, panel.scroll-cap);

                        body-flick := Flickable {
                            width: 100%;
                            height: 100%;
                            viewport-width: self.width;
                            viewport-height: scroll-content.preferred-height;

                            scroll-content := VerticalLayout {
                                width: parent.width;
                                alignment: start;

                                // --- Loading skeleton -------------------------------
                                // Placeholder rows while the live load is in flight.
                                // No cached instant-paint, so the results never jump
                                // from a cached to a fresh state — one clean paint.
                                if SearchState.cortinilla-loading: VerticalLayout {
                                    padding-top: 4px;
                                    CortinillaSkeletonRow { }
                                    CortinillaSkeletonRow { }
                                    CortinillaSkeletonRow { }
                                    CortinillaSkeletonRow { }
                                    CortinillaSkeletonRow { }
                                }

                                // --- Loaded content ---------------------------------
                                if !SearchState.cortinilla-loading: VerticalLayout {
                                    alignment: start;

                                    // No results: explicit empty-state line.
                                    if SearchState.top-result.id == ""
                                        && SearchState.sections.length == 0: Rectangle {
                                        height: 28px;
                                        HorizontalLayout {
                                            padding-left: 14px;
                                            padding-right: 14px;
                                            Text {
                                                text: @tr("No results for") + " “" + SearchState.cortinilla-query + "”";
                                                color: Theme.text-muted;
                                                font-size: 12px;
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                            }
                                        }
                                    }

                                    // Top result (flat-index 0).
                                    if SearchState.top-result.id != "": VerticalLayout {
                                        padding-left: 6px;
                                        padding-right: 6px;
                                        padding-top: 4px;
                                        Text {
                                            text: @tr("Top result");
                                            color: Theme.text-muted;
                                            font-size: 11px;
                                            font-weight: Typography.semibold;
                                            height: 22px;
                                            vertical-alignment: center;
                                            x: 10px;
                                        }
                                        CortinillaResultRow {
                                            item: SearchState.top-result;
                                            selected-index: SearchState.selected-index;
                                            clicked(fi) => {
                                                root.row-clicked(fi);
                                            }
                                            // Hover is purely visual (the row's own
                                            // has-hover highlight). It deliberately
                                            // does NOT write selected-index, so moving
                                            // the mouse never hijacks the keyboard
                                            // selection that Enter activates.
                                        }
                                    }

                                    // Result sections.
                                    for section[si] in SearchState.sections: VerticalLayout {
                                        padding-left: 6px;
                                        padding-right: 6px;
                                        padding-top: 4px;

                                        // Section header row.
                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 10px;
                                            height: 24px;
                                            Text {
                                                text: section.title;
                                                color: Theme.text-muted;
                                                font-size: 11px;
                                                font-weight: Typography.semibold;
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                            }
                                            if section.has-more: Rectangle {
                                                width: vm-text.preferred-width + 8px;
                                                vm-text := Text {
                                                    text: @tr("View more");
                                                    color: vm-ta.has-hover ? Theme.text-primary : Theme.accent;
                                                    font-size: 11px;
                                                    font-weight: Typography.medium;
                                                    vertical-alignment: center;
                                                    horizontal-alignment: right;
                                                }
                                                vm-ta := TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => {
                                                        root.view-more(section.kind);
                                                    }
                                                }
                                            }
                                        }

                                        // Section rows.
                                        for entry[ri] in section.rows: CortinillaResultRow {
                                            item: entry;
                                            selected-index: SearchState.selected-index;
                                            clicked(fi) => {
                                                root.row-clicked(fi);
                                            }
                                            // Hover is purely visual (the row's own
                                            // has-hover highlight). It deliberately
                                            // does NOT write selected-index, so moving
                                            // the mouse never hijacks the keyboard
                                            // selection that Enter activates.
                                        }
                                    }
                                }
                            }
                        }

                        // Auto-hiding scrollbar in its own gutter, shown only when
                        // the body overflows (ListScrollbar self-hides at
                        // max-scroll <= 0). Matches the app's Flickable idiom.
                        ListScrollbar {
                            x: parent.width - self.width;
                            width: 10px;
                            height: 100%;
                            auto-hide: true;
                            viewport-height: body-flick.viewport-height;
                            visible-height: body-flick.height;
                            viewport-y <=> body-flick.viewport-y;
                        }
                    }
                }
            }
        }
    }
}
