// PurchaseDetailView — the purchase detail + download screen
// (source-of-truth §2.2). 1:1 port of `PurchaseAlbumDetailView.svelte`:
// back button + loading/RAW-error states + 224×224 header (with the
// unavailable overlay) + actions row (Play-album / Download-all / format
// dropdown) + the count-based progress section + the Add-to-Library green
// block + the disc-grouped track table with the bespoke 4-state download row.
//
// All download/format math runs in Rust (crate::purchases); this file is the
// chrome and binds `PurchaseDetailState` / fires `PurchaseDetailActions`. The
// track table reproduces the Tauri bespoke detail row (BARE-quality column
// §A.6, the 4-state download control, disc grouping) rather than threading
// Purchases-only flags through the shared TrackRow — the faithful 1:1.
//
// REACTIVE RELOAD (§A.3): the root watches `PurchaseDetailState.album-id` and
// fires `PurchaseDetailActions.load(id)` on change + first mount, so navigating
// between two purchase albums RE-FETCHES instead of showing stale data. (The
// Tauri view relies on a conditional remount; a persistent Slint page must
// watch the bound id explicitly.)

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { Spacing } from "../foundation/spacing.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";
import { LoadingSpinner } from "../primitives/LoadingSpinner.slint";
import { CircleAction } from "../primitives/CircleAction.slint";
import { QbzSelect } from "../primitives/QbzSelect.slint";
import { NavButtons } from "../shell/NavButtons.slint";
import {
    PurchaseDetailState,
    PurchaseDetailActions,
    PurchaseDetailTrack,
} from "../state.slint";

// ── One detail track row (bespoke, §2.2.5) ──────────────────────────────────
// # | title (+ 2nd-line performer) | duration | quality (BARE) | download.
// `is-downloaded` dims the row to .6 and renders the green redownload check;
// `show-download` gates the whole control (album not downloadable AND not
// downloaded → no button). The download button is hover-revealed via opacity,
// except failed/redownload which stay visible.
component DetailTrackRow inherits Rectangle {
    in property <PurchaseDetailTrack> track;
    in property <bool> active: false;
    in property <bool> playing: false;
    callback play();
    callback download();

    height: 48px;
    border-radius: Radius.sm;
    background: root.active ? Theme.alpha-10
        : (row-ta.has-hover && root.track.streamable ? Theme.surface-hover : transparent);
    // Downloaded rows dim to .6 (Svelte `.complete` opacity).
    opacity: root.track.is-downloaded ? 0.6 : 1.0;

    // Row click → play (only when streamable). Declared first so the per-cell
    // download TouchArea (a child, hit-tested later) still wins.
    row-ta := TouchArea {
        enabled: root.track.streamable;
        mouse-cursor: root.track.streamable ? pointer : default;
        clicked => { root.play(); }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 12px;

        // # / playing-bars / downloading-spinner.
        VerticalLayout {
            alignment: center;
            width: 28px;
            // Playing → three animated bars (the active-track indicator).
            if root.active && root.playing: HorizontalLayout {
                alignment: center;
                spacing: 2px;
                Rectangle { width: 3px; height: 12px; background: Theme.accent; border-radius: 1px; }
                Rectangle { width: 3px; height: 8px; background: Theme.accent; border-radius: 1px; }
                Rectangle { width: 3px; height: 14px; background: Theme.accent; border-radius: 1px; }
            }
            if !(root.active && root.playing) && root.track.dl-status == "downloading": LoadingSpinner {
                size: 14px;
            }
            if !(root.active && root.playing) && root.track.dl-status != "downloading": Text {
                text: root.track.track-number;
                color: root.active ? Theme.accent : Theme.text-muted;
                font-size: Typography.legal;
                horizontal-alignment: center;
            }
        }

        // Title (+ 2nd-line performer when ≠ album artist).
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;
            Text {
                text: root.track.title;
                color: root.active ? Theme.accent : Theme.text-primary;
                font-size: Typography.body;
                font-weight: Typography.medium;
                overflow: elide;
            }
            if root.track.show-performer: Text {
                text: root.track.performer;
                color: Theme.text-muted;
                font-size: Typography.legal;
                overflow: elide;
            }
        }

        // Duration.
        VerticalLayout {
            alignment: center;
            width: 44px;
            Text {
                text: root.track.duration;
                color: Theme.text-muted;
                font-size: Typography.legal;
                horizontal-alignment: right;
            }
        }

        // Quality — BARE "{bit}/{rate}" (§A.6).
        VerticalLayout {
            alignment: center;
            width: 64px;
            Text {
                text: root.track.quality;
                color: Theme.text-secondary;
                font-size: Typography.legal;
                horizontal-alignment: right;
            }
        }

        // Download control (4 states). Hidden entirely when not downloadable
        // and not downloaded (§2.2.5).
        VerticalLayout {
            alignment: center;
            width: 32px;
            if root.track.show-download: dl-slot := Rectangle {
                width: 30px;
                height: 30px;
                border-radius: 6px;
                background: dl-ta.has-hover ? Theme.surface-elevated : transparent;
                // Idle button hover-revealed; downloaded/failed stay visible.
                opacity: (root.track.is-downloaded
                    || root.track.dl-status == "failed"
                    || root.track.dl-status == "downloading"
                    || row-ta.has-hover) ? 1.0 : 0.0;

                // 1:1 branch ORDER (Svelte col-download :432-459): `isDownloaded`
                // is checked FIRST, BEFORE `status === 'downloading'`. So on a
                // redownload of an already-downloaded track (is-downloaded AND
                // downloading) the redownload check shows here in the download
                // column — the spinner only appears in the col-number. Do NOT
                // check "downloading" first (§gap).
                //
                // downloaded → green check (download on hover) — clickable redownload.
                if root.track.is-downloaded: QbzIcon {
                    source: dl-ta.has-hover
                        ? @image-url("../assets/icons/download.svg")
                        : @image-url("../assets/icons/check.svg");
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: dl-ta.has-hover ? Theme.text-primary : Theme.success;
                }
                // else downloading → spinner, no button.
                if !root.track.is-downloaded && root.track.dl-status == "downloading": LoadingSpinner {
                    size: 14px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
                // else failed → red triangle-alert (retry).
                if !root.track.is-downloaded && root.track.dl-status == "failed": QbzIcon {
                    source: @image-url("../assets/icons/triangle-alert.svg");
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: Theme.danger;
                }
                // else idle → plain download (Svelte `else if album.downloadable`;
                // `show-download` already gates the slot to downloadable for the
                // not-downloaded case, so this implicitly only renders when
                // downloadable).
                if !root.track.is-downloaded
                    && root.track.dl-status != "downloading"
                    && root.track.dl-status != "failed": QbzIcon {
                    source: @image-url("../assets/icons/download.svg");
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: dl-ta.has-hover ? Theme.text-primary : Theme.text-muted;
                }
                dl-ta := TouchArea {
                    // Clickable except while the spinner shows (downloading AND
                    // not a redownload of an owned track) — the redownload check
                    // IS a clickable button (Svelte's `.redownload` button), so a
                    // downloading owned track stays clickable here.
                    enabled: root.track.is-downloaded || root.track.dl-status != "downloading";
                    mouse-cursor: pointer;
                    clicked => { root.download(); }
                }
            }
        }
    }
}

export component PurchaseDetailView inherits Rectangle {
    background: Theme.surface-main;

    // ── REACTIVE RELOAD (§A.3) ──────────────────────────────────────────────
    // Fire a fresh load whenever the bound album id changes (and on first
    // mount). A persistent Slint page would otherwise show stale data when the
    // id is swapped without a remount.
    property <string> watched-id: PurchaseDetailState.album-id;
    function maybe-load() {
        if (PurchaseDetailState.album-id != "") {
            PurchaseDetailActions.load(PurchaseDetailState.album-id);
        }
    }
    init => { self.maybe-load(); }
    changed watched-id => { self.maybe-load(); }

    flick := Flickable {
        width: parent.width;
        viewport-width: self.width;
        viewport-height: page.preferred-height;

        page := VerticalLayout {
            width: parent.width;
            padding-left: 32px;
            padding-right: 32px;
            padding-top: 11px;
            padding-bottom: 100px;
            spacing: 0px;
            alignment: start;

            // --- History navigation (back button, always at top) -------------
            HorizontalLayout {
                alignment: start;
                NavButtons { }
            }

            Rectangle { height: 22px; }

            // --- Loading / RAW-error states ----------------------------------
            if PurchaseDetailState.loading: Rectangle {
                height: 200px;
                LoadingSpinner {
                    size: 36px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }
            // Error is the RAW string (NOT i18n-mapped, unlike the list view).
            if !PurchaseDetailState.loading && PurchaseDetailState.load-error != "": Rectangle {
                height: 200px;
                Text {
                    text: PurchaseDetailState.load-error;
                    color: Theme.text-secondary;
                    font-size: Typography.body;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }

            // --- Loaded content ----------------------------------------------
            if !PurchaseDetailState.loading
                && PurchaseDetailState.load-error == ""
                && PurchaseDetailState.loaded: VerticalLayout {
                spacing: 0px;
                alignment: start;

                // ── Header ────────────────────────────────────────────────
                HorizontalLayout {
                    spacing: 32px;

                    // 224×224 artwork. Unavailable → hide img + TriangleAlert
                    // overlay (§2.2.4).
                    Rectangle {
                        width: 224px;
                        height: 224px;
                        border-radius: 12px;
                        background: Theme.surface-elevated;
                        drop-shadow-blur: 32px;
                        drop-shadow-color: #00000080;
                        drop-shadow-offset-y: 8px;
                        clip: true;
                        if PurchaseDetailState.downloadable
                            && PurchaseDetailState.artwork.width > 0: Image {
                            width: 100%;
                            height: 100%;
                            source: PurchaseDetailState.artwork;
                            image-fit: cover;
                        }
                        if PurchaseDetailState.downloadable
                            && PurchaseDetailState.artwork.width == 0: QbzIcon {
                            source: @image-url("../assets/icons/music.svg");
                            width: 48px;
                            height: 48px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            tint: Theme.text-muted;
                        }
                        // Unavailable overlay (TriangleAlert + label).
                        if !PurchaseDetailState.downloadable: Rectangle {
                            background: Theme.surface-elevated;
                            VerticalLayout {
                                alignment: center;
                                spacing: 8px;
                                HorizontalLayout {
                                    alignment: center;
                                    QbzIcon {
                                        source: @image-url("../assets/icons/triangle-alert.svg");
                                        width: 18px;
                                        height: 18px;
                                        tint: Theme.text-muted;
                                    }
                                }
                                Text {
                                    text: @tr("Unavailable");
                                    color: Theme.text-muted;
                                    font-size: Typography.legal;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }

                    // Metadata column.
                    VerticalLayout {
                        alignment: start;
                        padding-top: 4px;
                        spacing: 0px;
                        horizontal-stretch: 1;

                        Text {
                            text: PurchaseDetailState.title;
                            color: Theme.text-primary;
                            font-size: Typography.section;
                            font-weight: Typography.bold;
                            overflow: elide;
                        }
                        Rectangle { height: 4px; }
                        // Artist — Svelte renders the clickable link whenever
                        // `onArtistClick` is present, and +page.svelte ALWAYS
                        // passes it (even for artist id 0). So always a link;
                        // open-artist gets the (possibly empty) id verbatim.
                        HorizontalLayout {
                            alignment: start;
                            artist-area := TouchArea {
                                width: artist-text.preferred-width;
                                height: artist-text.preferred-height;
                                mouse-cursor: pointer;
                                clicked => {
                                    PurchaseDetailActions.open-artist(PurchaseDetailState.artist-id);
                                }
                                artist-text := Text {
                                    text: PurchaseDetailState.artist;
                                    color: artist-area.has-hover
                                        ? Theme.text-primary
                                        : Theme.text-secondary;
                                    font-size: Typography.heading;
                                    font-weight: Typography.bold;
                                }
                            }
                        }
                        Rectangle { height: 10px; }
                        // Info line: purchasedOn + LONG-month date, then
                        // · label · genre (each conditional).
                        HorizontalLayout {
                            alignment: start;
                            spacing: 0px;
                            if PurchaseDetailState.purchased-on != "": Text {
                                text: @tr("Purchased on") + " " + PurchaseDetailState.purchased-on;
                                color: Theme.text-muted;
                                font-size: Typography.legal;
                                vertical-alignment: center;
                            }
                            if PurchaseDetailState.label-name != "": Text {
                                // 1:1 quirk (§gap): the leading middot before the
                                // label is emitted ONLY when purchased-on is
                                // present (Svelte `{#if album.purchased_at} &middot; {/if}`
                                // before the label, :262). With no purchased_at but
                                // a label, Svelte renders the label with NO leading
                                // dot — so drop it here too.
                                text: (PurchaseDetailState.purchased-on != "" ? "   •   " : "")
                                    + PurchaseDetailState.label-name;
                                color: Theme.text-muted;
                                font-size: Typography.legal;
                                vertical-alignment: center;
                            }
                            if PurchaseDetailState.genre-name != "": Text {
                                // Genre ALWAYS gets a leading middot (Svelte's
                                // `{#if album.genre} &middot; {genre} {/if}`, :265-266
                                // — unconditional), even with no purchased_at and
                                // no label.
                                text: "   •   " + PurchaseDetailState.genre-name;
                                color: Theme.text-muted;
                                font-size: Typography.legal;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle { height: 6px; }
                        // Quality + stats line.
                        HorizontalLayout {
                            alignment: start;
                            spacing: 0px;
                            if PurchaseDetailState.quality != "": Text {
                                text: PurchaseDetailState.quality;
                                color: Theme.accent;
                                font-size: Typography.legal;
                                font-weight: Typography.semibold;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle { height: 4px; }
                        Text {
                            // "{count} tracks · {duration}". Svelte uses
                            // `purchases.tracksCount` with `{count}` interpolation;
                            // preserve the placeholder via Slint's `@tr("{} …", n)`
                            // so the Slice-13 catalog can back it (§8.5).
                            text: @tr("{} tracks", PurchaseDetailState.total-tracks)
                                + "   •   "
                                + PurchaseDetailState.total-duration;
                            color: Theme.text-muted;
                            font-size: Typography.legal;
                        }

                        // ── Actions row (only if downloadable) ────────────
                        if PurchaseDetailState.downloadable: VerticalLayout {
                            Rectangle { height: 20px; }
                            HorizontalLayout {
                                alignment: start;
                                spacing: 12px;
                                // Play-album circle.
                                if PurchaseDetailState.show-play: CircleAction {
                                    icon: @image-url("../assets/icons/play-fill.svg");
                                    primary: true;
                                    // Plain page background — theme-aware
                                    // variant so it reads on light themes.
                                    on-surface: true;
                                    tooltip: @tr("Play");
                                    clicked => { PurchaseDetailActions.play-album(); }
                                }
                                // Download-all circle. `.primary` only when no
                                // play button. Spinner while downloading-all.
                                VerticalLayout {
                                    alignment: center;
                                    CircleAction {
                                        icon: @image-url("../assets/icons/download.svg");
                                        primary: !PurchaseDetailState.show-play;
                                        on-surface: true;
                                        loading: PurchaseDetailState.is-downloading-all;
                                        enabled: PurchaseDetailState.can-download-all;
                                        tooltip: @tr("Download all");
                                        clicked => { PurchaseDetailActions.download-all(); }
                                    }
                                }
                                // Format dropdown (only when formats exist).
                                if PurchaseDetailState.has-formats: VerticalLayout {
                                    alignment: center;
                                    QbzSelect {
                                        options: PurchaseDetailState.format-labels;
                                        current-index: PurchaseDetailState.format-index;
                                        sm: true;
                                        menu-width: 220px;
                                        selected(i) => {
                                            PurchaseDetailActions.select-format(i);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Progress section (downloadingAll || allComplete ||
                //    wasCancelled) ──────────────────────────────────────────
                if PurchaseDetailState.show-progress: VerticalLayout {
                    Rectangle { height: 24px; }
                    HorizontalLayout {
                        alignment: start;
                        spacing: 8px;
                        // allComplete → Check + complete.
                        if PurchaseDetailState.all-complete: QbzIcon {
                            source: @image-url("../assets/icons/check.svg");
                            width: 14px;
                            height: 14px;
                            tint: Theme.success;
                        }
                        if PurchaseDetailState.all-complete: Text {
                            text: @tr("Download complete");
                            color: Theme.text-secondary;
                            font-size: Typography.legal;
                            vertical-alignment: center;
                        }
                        // wasCancelled → X + "Cancelled ({completed}/{total})".
                        if !PurchaseDetailState.all-complete
                            && PurchaseDetailState.was-cancelled: QbzIcon {
                            source: @image-url("../assets/icons/x.svg");
                            width: 14px;
                            height: 14px;
                            tint: Theme.text-muted;
                        }
                        if !PurchaseDetailState.all-complete
                            && PurchaseDetailState.was-cancelled: Text {
                            // `purchases.downloadCancelled` {completed}{total} —
                            // single @tr placeholder form so the Slice-13 catalog
                            // backs it (NOT concatenated @tr fragments; §8.5).
                            text: @tr("Download cancelled ({}/{})",
                                PurchaseDetailState.completed-count,
                                PurchaseDetailState.total-tracks);
                            color: Theme.text-secondary;
                            font-size: Typography.legal;
                            vertical-alignment: center;
                        }
                        // downloading → spinner + "Downloading {current}/{total}"
                        // + cancel button.
                        if !PurchaseDetailState.all-complete
                            && !PurchaseDetailState.was-cancelled: LoadingSpinner { size: 14px; }
                        if !PurchaseDetailState.all-complete
                            && !PurchaseDetailState.was-cancelled: Text {
                            // `purchases.downloadProgress` {current}{total} —
                            // single @tr placeholder form (NOT concatenated @tr
                            // fragments; §8.5). Trailing "..." matches Tauri source.
                            text: @tr("Downloading {}/{}...",
                                PurchaseDetailState.completed-count,
                                PurchaseDetailState.total-tracks);
                            color: Theme.text-secondary;
                            font-size: Typography.legal;
                            vertical-alignment: center;
                        }
                        if !PurchaseDetailState.all-complete
                            && !PurchaseDetailState.was-cancelled: Rectangle {
                            width: 8px;
                        }
                        if !PurchaseDetailState.all-complete
                            && !PurchaseDetailState.was-cancelled: cancel-btn := Rectangle {
                            height: 26px;
                            border-radius: 6px;
                            background: cancel-ta.has-hover ? Theme.surface-hover : Theme.surface-elevated;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 10px;
                                spacing: 4px;
                                VerticalLayout {
                                    alignment: center;
                                    QbzIcon {
                                        source: @image-url("../assets/icons/x.svg");
                                        width: 12px;
                                        height: 12px;
                                        tint: Theme.text-secondary;
                                    }
                                }
                                Text {
                                    text: @tr("Cancel");
                                    color: Theme.text-secondary;
                                    font-size: Typography.legal;
                                    vertical-alignment: center;
                                }
                            }
                            cancel-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { PurchaseDetailActions.cancel-download(); }
                            }
                        }
                    }
                    Rectangle { height: 8px; }
                    // Progress bar — fill = completedCount/totalTracks*100 (NOT
                    // format-scoped, §A.4); classes complete/cancelled.
                    Rectangle {
                        height: 4px;
                        border-radius: 2px;
                        background: Theme.surface-elevated;
                        clip: true;
                        Rectangle {
                            x: 0;
                            width: parent.width * (PurchaseDetailState.progress-percent / 100);
                            height: parent.height;
                            border-radius: 2px;
                            background: PurchaseDetailState.all-complete
                                ? Theme.success
                                : (PurchaseDetailState.was-cancelled
                                    ? Theme.text-muted
                                    : Theme.accent);
                        }
                    }
                }

                // ── Add-to-Library block (allComplete && destination) ─────
                if PurchaseDetailState.show-add-to-library: VerticalLayout {
                    Rectangle { height: 20px; }
                    Rectangle {
                        height: 64px;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.success;
                        background: Theme.alpha-10;
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 16px;
                            // DOM order matches Svelte `.add-to-library`
                            // (display:flex): [button] then [desc].
                            // Button (LEFT).
                            VerticalLayout {
                                alignment: center;
                                add-btn := Rectangle {
                                    height: 34px;
                                    width: 160px;
                                    border-radius: 6px;
                                    // Svelte `.add-to-library-btn` is
                                    // `background: var(--success)` GREEN; hover
                                    // is `opacity: 0.9` (no color change).
                                    background: Theme.success;
                                    opacity: PurchaseDetailState.adding-to-library
                                        ? 0.6
                                        : (add-ta.has-hover ? 0.9 : 1.0);
                                    HorizontalLayout {
                                        alignment: center;
                                        spacing: 6px;
                                        VerticalLayout {
                                            alignment: center;
                                            if PurchaseDetailState.adding-to-library: LoadingSpinner {
                                                size: 14px;
                                            }
                                            if !PurchaseDetailState.adding-to-library: QbzIcon {
                                                source: @image-url("../assets/icons/library.svg");
                                                width: 14px;
                                                height: 14px;
                                                tint: white;
                                            }
                                        }
                                        Text {
                                            text: @tr("Add to library");
                                            color: white;
                                            font-size: Typography.legal;
                                            font-weight: Typography.semibold;
                                            vertical-alignment: center;
                                        }
                                    }
                                    add-ta := TouchArea {
                                        enabled: !PurchaseDetailState.adding-to-library;
                                        mouse-cursor: pointer;
                                        clicked => { PurchaseDetailActions.add-to-library(); }
                                    }
                                }
                            }
                            // Description (RIGHT). Single span — the "Add to
                            // library" label exists ONLY on the button in Svelte.
                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;
                                Text {
                                    text: @tr("Add these downloaded tracks to your local library.");
                                    color: Theme.text-muted;
                                    font-size: Typography.legal;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }

                // ── Divider ───────────────────────────────────────────────
                Rectangle { height: 24px; }
                Rectangle { height: 1px; background: Theme.border-subtle; }
                Rectangle { height: 12px; }

                // ── Track table ───────────────────────────────────────────
                VerticalLayout {
                    spacing: 0px;
                    // Header row: # | title | duration | quality | <Download>.
                    Rectangle {
                        height: 32px;
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 12px;
                            Text {
                                text: "#";
                                width: 28px;
                                color: Theme.text-muted;
                                font-size: Typography.legal;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Text {
                                text: @tr("Title");
                                horizontal-stretch: 1;
                                color: Theme.text-muted;
                                font-size: Typography.legal;
                                vertical-alignment: center;
                            }
                            Text {
                                text: @tr("Duration");
                                width: 44px;
                                color: Theme.text-muted;
                                font-size: Typography.legal;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                            Text {
                                text: @tr("Quality");
                                width: 64px;
                                color: Theme.text-muted;
                                font-size: Typography.legal;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                            VerticalLayout {
                                alignment: center;
                                width: 32px;
                                HorizontalLayout {
                                    alignment: center;
                                    QbzIcon {
                                        source: @image-url("../assets/icons/download.svg");
                                        width: 14px;
                                        height: 14px;
                                        tint: Theme.text-muted;
                                    }
                                }
                            }
                        }
                    }

                    // Each row, preceded by a "Disc N" divider when the model
                    // marks it (multi-disc only; single-disc → header-number 0
                    // never fires → flat list). Mirrors groupByDisc + isMultiDisc.
                    for track[index] in PurchaseDetailState.tracks: VerticalLayout {
                        spacing: 0px;
                        if track.disc-header-number > 0: Rectangle {
                            height: 40px;
                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                Text {
                                    text: @tr("Disc") + " \{track.disc-header-number}";
                                    color: Theme.text-muted;
                                    font-size: Typography.legal;
                                    font-weight: 600;
                                    letter-spacing: 0.5px;
                                    vertical-alignment: center;
                                    horizontal-alignment: left;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                        DetailTrackRow {
                            track: track;
                            active: PurchaseDetailState.active-track-id == track.id;
                            playing: PurchaseDetailState.playback-active
                                && PurchaseDetailState.active-track-id == track.id;
                            play => {
                                PurchaseDetailActions.play-track(track.id);
                            }
                            download => {
                                PurchaseDetailActions.download-track(track.id);
                            }
                        }
                    }
                }
            }
        }
    }
}
