// Album detail page.
//
// Mirrors the Svelte AlbumDetailView: back button, an album header
// (artwork + title / artist / info line / action buttons), a divider,
// and the track list with a column header. Data comes from the
// AlbumState global; the action buttons are visual for now.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { Spacing } from "../foundation/spacing.slint";
import { AlbumState, AlbumActions, ArtworkActions, NavState, ContentView, DragState, NowPlayingState, ShellState, TooltipState, AppearanceState, UiFocusState } from "../state.slint";
import { TrackRow } from "../primitives/TrackRow.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";
import { ContextMenu } from "../primitives/ContextMenu.slint";
import { ContextMenuItem } from "../primitives/ContextMenuItem.slint";
import { QualityBadgeFull } from "../primitives/QualityBadgeFull.slint";
import { TrackPlayCell } from "../primitives/TrackPlayCell.slint";
import { TrackContextMenu } from "../primitives/TrackContextMenu.slint";
import { AlbumContextMenu } from "../primitives/AlbumContextMenu.slint";
import { DiscHeaderMenu } from "../primitives/DiscHeaderMenu.slint";
import { LoadingSpinner } from "../primitives/LoadingSpinner.slint";
import { ListScrollbar } from "../primitives/ListScrollbar.slint";
import { CircleAction } from "../primitives/CircleAction.slint";
import { MultiSelectBar } from "../primitives/MultiSelectBar.slint";
import { NavButtons } from "../shell/NavButtons.slint";
import { ImmersiveAtmosphere } from "../immersive/ImmersiveAtmosphere.slint";
import { Carousel } from "../discover/Carousel.slint";

// One label/award entry in the album sidebar — a round gradient avatar
// and a name. In `compact` mode the name is dropped (the rail is an
// icon-only strip) and shown in a hover tooltip instead.
component SidebarCard inherits Rectangle {
    in property <image> icon;
    in property <string> name;
    in property <brush> avatar-bg;
    in property <bool> compact: false;
    callback clicked();

    height: 48px;
    border-radius: Radius.sm;
    background: ta.has-hover ? Theme.surface-hover : transparent;

    HorizontalLayout {
        padding: 6px;
        spacing: 10px;
        alignment: root.compact ? center : start;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 28px;
                height: 28px;
                border-radius: 14px;
                background: root.avatar-bg;
                QbzIcon {
                    source: root.icon;
                    width: 13px;
                    height: 13px;
                    x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                    y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                    tint: #ffffff;
                }
            }
        }
        if !root.compact: VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: root.name;
                color: Theme.text-secondary;
                // -2pts vs the Typography.link (14px) base — the label/award
                // NAME is what needed trimming, not the LABEL/AWARDS heading.
                font-size: 12px;
                font-weight: Typography.medium;
                wrap: word-wrap;
            }
        }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        // Compact rail: the name lives in a hover tooltip.
        changed has-hover => {
            if (self.has-hover && root.compact && root.name != "") {
                TooltipState.text = root.name;
                TooltipState.anchor-x = root.absolute-position.x + root.width / 2;
                TooltipState.anchor-y = root.absolute-position.y;
                TooltipState.show = true;
            } else if (!self.has-hover) {
                TooltipState.show = false;
            }
        }
        clicked => {
            root.clicked();
        }
    }
}

component SidebarHeading inherits Text {
    color: Theme.text-muted;
    font-size: 10px;
    font-weight: Typography.semibold;
    letter-spacing: 1px;
}

// One external-link brand icon in the album sidebar — the bare brand SVG
// rendered with its native colors (no tint), no visible label; the name
// shows in a hover tooltip (Feishin-style inline links).
component BrandLink inherits Rectangle {
    in property <image> icon;
    in property <string> name;
    callback clicked();

    width: 30px;
    height: 30px;
    border-radius: Radius.sm;
    background: ta.has-hover ? Theme.surface-hover : transparent;

    Image {
        source: root.icon;
        width: 20px;
        height: 20px;
        image-fit: contain;
        x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
        y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
        opacity: ta.has-hover ? 1.0 : 0.92;
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        changed has-hover => {
            if (self.has-hover && root.name != "") {
                TooltipState.text = root.name;
                TooltipState.anchor-x = root.absolute-position.x + root.width / 2;
                TooltipState.anchor-y = root.absolute-position.y;
                TooltipState.show = true;
            } else if (!self.has-hover) {
                TooltipState.show = false;
            }
        }
        clicked => {
            root.clicked();
        }
    }
}

export component AlbumPageView inherits Rectangle {
    callback open-artist(string);
    callback media-action(string, string, string);

    // Whether the full-description modal is open.
    property <bool> show-description: false;
    // Header description picks the SHORTER cutoff when the content area is
    // space-constrained (window <1366 AND a right panel open), so the tracks
    // keep priority; back to the full short text when there's room.
    property <string> desc-display:
        ShellState.content-constrained
            ? AlbumState.description-shorter
            : AlbumState.description-short;

    // Header text colors: the header sits on a DARK backdrop when either the
    // album-header-gradient atmosphere is on OR the app-wide dynamic background
    // is active — in both cases the text must be light regardless of theme.
    // `header-atmo-on` gates the album's OWN blurred atmosphere: it is suppressed
    // under the dynamic background (they clash — owner 2026-07-17), so the header
    // shows the dynamic background instead.
    property <bool> header-light: AppearanceState.album-header-gradient || ShellState.app-background-active;
    property <bool> header-atmo-on: AppearanceState.album-header-gradient && !ShellState.app-background-active;
    property <color> hdr-strong: header-light
        ? #ffffff : Theme.text-primary;
    property <color> hdr-body: header-light
        ? #ffffff.with-alpha(0.88) : Theme.text-secondary;
    property <color> hdr-muted: header-light
        ? #ffffff.with-alpha(0.62) : Theme.text-muted;

    // With no dark header backdrop the CircleActions sit on the plain theme
    // surface — switch them to the theme-aware on-surface variant so they stay
    // visible on light themes (their default palette is white-on-dark).
    property <bool> hdr-on-surface: !header-light;

    // Atmosphere/gradient extent: the background blocks must end EXACTLY at
    // the header/track-list divider — the header height varies (long
    // editorial descriptions), so a fixed px either overshoots into the
    // track list or fades early. `header-divider.y` is the divider's offset
    // within `page`, and the backgrounds share the page's top origin inside
    // the Flickable viewport (page.y = its own offset there, normally 0).
    // The backgrounds are absolutely positioned and don't participate in
    // the page layout, so this cannot form a binding loop.
    property <length> atmo-height: page.y + header-divider.y;

    background: ShellState.app-background-active ? transparent : Theme.surface-main;

    flick := Flickable {
        // Full-width: the gradient + page background bleed edge-to-edge so
        // there is no dark right gutter. Content stays clear of the scrollbar
        // via the page's 32px right padding — the scrollbar lives in the
        // outer 18px (parent.width-18 .. parent.width-4), and every text /
        // track / label-rail child ends at parent.width-32, a 14px gap, so
        // nothing paints under it. The gradient is the only thing reaching
        // the edge, which is exactly the desired full-bleed colour. (The
        // earlier `parent.width - 20px` clipped the gradient too, leaving an
        // ugly dark gutter strip on the right.)
        width: parent.width;
        // Freeze scroll during a track drag so the ghost doesn't drift.
        interactive: !DragState.active;
        viewport-width: self.width;
        viewport-height: page.preferred-height;
        // Scroll-position restore on back/forward (see nav::scope_for).
        property <string> sr-armed: NavState.restore-scope;
        function sr-restore() {
            if (NavState.restore-scope == "album" && self.viewport-height > self.height) {
                self.viewport-y = NavState.scroll-restore;
                NavState.restore-scope = "";
            }
        }
        init => { self.sr-restore(); }
        changed sr-armed => { self.sr-restore(); }
        changed viewport-height => { self.sr-restore(); }
        changed viewport-y => { NavState.report-scroll(self.viewport-y); }

        // Static Immersive-style blurred artwork field behind the header;
        // scrolls with content when the appearance setting is enabled.
        if root.header-atmo-on && AlbumState.header-atmosphere.width > 0: ImmersiveAtmosphere {
            x: 0;
            y: 0;
            width: parent.width;
            height: root.atmo-height;
            source-image: AlbumState.header-atmosphere;
            fallback-image: AlbumState.artwork;
            animated: false;
            dim: 0.24;
            base-opacity: 0.92;
            warp-opacity: 0.38;
        }
        if root.header-atmo-on && AlbumState.header-atmosphere.width <= 0: Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: root.atmo-height;
            background: @linear-gradient(180deg,
                AlbumState.header-color 0%,
                AlbumState.header-color 16%,
                transparent 100%);
        }
        if root.header-atmo-on: Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: root.atmo-height;
            // Fade start sits proportionally near the bottom so the blend
            // to surface-main always COMPLETES right at the divider,
            // whatever height the header resolved to.
            background: @linear-gradient(180deg,
                transparent 0%,
                transparent 82%,
                Theme.surface-main 100%);
        }

        page := VerticalLayout {
            width: parent.width;
            // padding matches Discover so the [<] [>] pair sits at the same
            // top/left margin across every view.
            padding-left: 32px;
            padding-right: 32px;
            padding-top: 11px;
            padding-bottom: 100px;
            spacing: 0px;
            alignment: start;

            // --- History navigation ------------------------------------------
            HorizontalLayout {
                alignment: start;
                NavButtons { }
            }

            Rectangle { height: 22px; }

            // --- Album header ------------------------------------------------
            HorizontalLayout {
                spacing: 32px;

                Rectangle {
                    width: 224px;
                    height: 224px;
                    border-radius: 12px;
                    background: Theme.surface-elevated;
                    drop-shadow-blur: 32px;
                    drop-shadow-color: #00000080;
                    drop-shadow-offset-y: 8px;
                    clip: true;
                    Image {
                        width: 100%;
                        height: 100%;
                        source: AlbumState.artwork;
                        image-fit: cover;
                    }
                    // Right-click → cover context menu (same pattern
                    // as the artist portrait): Add/Change/Remove
                    // custom cover, Open in browser, Save as.
                    cover-ta := TouchArea {
                        mouse-cursor: default;
                        pointer-event(e) => {
                            if (e.button == PointerEventButton.right
                                && e.kind == PointerEventKind.up) {
                                cover-menu.show();
                            }
                        }
                    }
                    cover-menu := PopupWindow {
                        x: cover-ta.mouse-x;
                        y: cover-ta.mouse-y;
                        width: 220px;
                        // close-on-click races the row's TouchArea (can dismiss
                        // on the press before `clicked` fires); close only on
                        // outside clicks and dismiss explicitly per row. Matches
                        // Sidebar.slint / AlbumContextMenu.slint.
                        close-policy: close-on-click-outside;
                        ContextMenu {
                            if !AlbumState.has-custom-cover: ContextMenuItem {
                                icon: @image-url("../assets/icons/image-plus.svg");
                                label: @tr("Add cover");
                                clicked => {
                                    ArtworkActions.add-custom(
                                        "album", AlbumState.id);
                                    cover-menu.close();
                                }
                            }
                            if AlbumState.has-custom-cover: ContextMenuItem {
                                icon: @image-url("../assets/icons/image-plus.svg");
                                label: @tr("Change cover");
                                clicked => {
                                    ArtworkActions.add-custom(
                                        "album", AlbumState.id);
                                    cover-menu.close();
                                }
                            }
                            if AlbumState.has-custom-cover: ContextMenuItem {
                                icon: @image-url("../assets/icons/trash-2.svg");
                                label: @tr("Remove cover");
                                clicked => {
                                    ArtworkActions.remove-custom(
                                        "album", AlbumState.id);
                                    cover-menu.close();
                                }
                            }
                            Rectangle {
                                height: 1px;
                                background: Theme.border-subtle;
                            }
                            ContextMenuItem {
                                icon: @image-url("../assets/icons/external-link.svg");
                                label: @tr("Open in browser");
                                clicked => {
                                    ArtworkActions.open-in-browser(
                                        AlbumState.artwork-url);
                                    cover-menu.close();
                                }
                            }
                            ContextMenuItem {
                                icon: @image-url("../assets/icons/cloud-download.svg");
                                label: @tr("Save as…");
                                clicked => {
                                    ArtworkActions.save-as(
                                        AlbumState.artwork-url,
                                        AlbumState.title + " - Cover.jpg");
                                    cover-menu.close();
                                }
                            }
                        }
                    }
                }

                VerticalLayout {
                    alignment: start;
                    padding-top: 4px;
                    spacing: 0px;
                    horizontal-stretch: 1;

                    Text {
                        text: AlbumState.title;
                        color: root.hdr-strong;
                        font-size: Typography.section;
                        font-weight: Typography.bold;
                        overflow: elide;
                    }
                    Rectangle { height: 4px; }
                    // Full credited-artist line (E1): every contributor with its
                    // role (e.g. "Faust • Melnikov • Mozart (compositor)"), each
                    // name a clickable link to its artist page. Falls back to the
                    // single interpreter when the album carries no artists[] list.
                    HorizontalLayout {
                        alignment: start;
                        for credit[idx] in AlbumState.artists: HorizontalLayout {
                            if idx > 0: Text {
                                text: "  •  ";
                                color: root.hdr-body;
                                font-size: Typography.heading;
                                font-weight: Typography.bold;
                                vertical-alignment: center;
                            }
                            credit-area := TouchArea {
                                width: credit-text.preferred-width;
                                height: credit-text.preferred-height;
                                mouse-cursor: credit.id != "" ? pointer : default;
                                enabled: credit.id != "";
                                clicked => {
                                    root.open-artist(credit.id);
                                }
                                credit-text := Text {
                                    text: credit.name;
                                    color: credit-area.has-hover && credit.id != ""
                                        ? root.hdr-strong
                                        : root.hdr-body;
                                    font-size: Typography.heading;
                                    font-weight: Typography.bold;
                                }
                            }
                            if credit.role != "": Text {
                                text: " (" + credit.role + ")";
                                color: root.hdr-body;
                                font-size: Typography.heading;
                                font-weight: 400;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle { height: 10px; }
                    // Meta line. With a navigable label, render it inline as a
                    // clickable link (Tauri label-link: meta color, accent on
                    // hover) between the pre (year) and post (genre • tracks •
                    // duration) segments. Otherwise the plain full line.
                    if AlbumState.label-id != "" && AlbumState.label != "": HorizontalLayout {
                        alignment: start;
                        spacing: 0px;
                        Text {
                            text: AlbumState.meta-pre != "" ? AlbumState.meta-pre + "   •   " : "";
                            color: root.hdr-body;
                            font-size: Typography.body;
                            vertical-alignment: center;
                        }
                        label-area := TouchArea {
                            width: label-text.preferred-width;
                            height: label-text.preferred-height;
                            mouse-cursor: pointer;
                            clicked => {
                                root.media-action("label", AlbumState.label-id, "open");
                            }
                            label-text := Text {
                                text: AlbumState.label;
                                color: label-area.has-hover ? Theme.accent : root.hdr-body;
                                font-size: Typography.body;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: AlbumState.meta-post != "" ? "   •   " + AlbumState.meta-post : "";
                            color: root.hdr-body;
                            font-size: Typography.body;
                            vertical-alignment: center;
                        }
                    }
                    if AlbumState.label-id == "" || AlbumState.label == "": Text {
                        text: AlbumState.info-line;
                        color: root.hdr-body;
                        font-size: Typography.body;
                        overflow: elide;
                    }

                    // Editorial description — lives with the metadata and
                    // fills the width to the right of the artwork; truncated,
                    // with a Read more link to the full modal.
                    if AlbumState.description != "": Rectangle { height: 12px; }
                    if AlbumState.description != "": Text {
                        // Explicit width so the text fills the whole band
                        // to the right of the artwork instead of wrapping
                        // narrow and leaving dead space. Bound to root.width
                        // (not the parent layout) to avoid a binding loop:
                        // page padding 32+32, artwork 224, header gap 32.
                        width: root.width - 320px;
                        text: root.desc-display;
                        color: root.hdr-body;
                        font-size: Typography.legal;
                        wrap: word-wrap;
                    }
                    if AlbumState.description != root.desc-display: Rectangle { height: 4px; }
                    if AlbumState.description != root.desc-display: read-more := TouchArea {
                        width: read-more-row.preferred-width;
                        height: 20px;
                        mouse-cursor: pointer;
                        clicked => {
                            root.show-description = true;
                        }
                        read-more-row := HorizontalLayout {
                            Text {
                                text: @tr("Read more");
                                color: read-more.has-hover ? Theme.accent-hover : Theme.accent;
                                font-size: Typography.legal;
                                vertical-alignment: center;
                            }
                        }
                    }

                    Rectangle { height: 20px; }
                    HorizontalLayout {
                        alignment: start;
                        spacing: 12px;
                        CircleAction {
                            icon: @image-url("../assets/icons/play-fill.svg");
                            primary: true;
                            on-surface: root.hdr-on-surface;
                            // Spin only while THIS album's first track is fetching.
                            loading: NowPlayingState.loading
                                && NowPlayingState.album-id == AlbumState.id;
                            clicked => {
                                root.media-action("album", AlbumState.id, "play");
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            CircleAction {
                                icon: @image-url("../assets/icons/shuffle.svg");
                                on-surface: root.hdr-on-surface;
                                clicked => {
                                    root.media-action("album", AlbumState.id, "shuffle");
                                }
                            }
                        }
                        // Edit metadata (tag editor) — local albums only; hidden
                        // for Plex (tag write isn't supported there).
                        if AlbumState.is-local && AlbumState.source != "plex": VerticalLayout {
                            alignment: center;
                            CircleAction {
                                icon: @image-url("../assets/icons/pencil.svg");
                                on-surface: root.hdr-on-surface;
                                clicked => {
                                    root.media-action("album", AlbumState.id, "edit");
                                }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            CircleAction {
                                // Live library state: filled accent heart when
                                // favorited, outline otherwise; spinner while a
                                // toggle is in flight. "favorite-toggle" adds or
                                // removes (the grid hearts stay add-only).
                                icon: AlbumState.is-favorite
                                    ? @image-url("../assets/icons/heart-filled.svg")
                                    : @image-url("../assets/icons/heart.svg");
                                on-surface: root.hdr-on-surface;
                                active: AlbumState.is-favorite;
                                loading: AlbumState.favorite-loading;
                                clicked => {
                                    root.media-action("album", AlbumState.id, "favorite-toggle");
                                }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            CircleAction {
                                icon: @image-url("../assets/icons/radio.svg");
                                on-surface: root.hdr-on-surface;
                                clicked => {
                                    root.media-action("album", AlbumState.id, "radio");
                                }
                            }
                        }
                        if AlbumState.has-booklet: VerticalLayout {
                            alignment: center;
                            CircleAction {
                                icon: @image-url("../assets/icons/book-open.svg");
                                on-surface: root.hdr-on-surface;
                                clicked => {
                                    root.media-action("album", AlbumState.id, "booklet");
                                }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            CircleAction {
                                icon: @image-url("../assets/icons/cassette-tape.svg");
                                on-surface: root.hdr-on-surface;
                                clicked => {
                                    root.media-action("album", AlbumState.id, "add-to-mixtape");
                                }
                            }
                        }
                        // Album info (i) — opens the Album Info (Credits/Review)
                        // modal. Qobuz albums only (local albums have no Qobuz
                        // credits/review), 1:1 with Tauri's album-credits button.
                        if !AlbumState.is-local: VerticalLayout {
                            alignment: center;
                            CircleAction {
                                icon: @image-url("../assets/icons/info.svg");
                                on-surface: root.hdr-on-surface;
                                clicked => {
                                    root.media-action("album", AlbumState.id, "info");
                                }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 32px;
                                height: 32px;
                                CircleAction {
                                    icon: @image-url("../assets/icons/ellipsis.svg");
                                    on-surface: root.hdr-on-surface;
                                    clicked => {
                                        album-menu.show();
                                    }
                                }
                                // Opens below the ⋯, right edges aligned — the
                                // button sits at the right end of the action row
                                // so the menu drops leftward (negative x).
                                album-menu := AlbumContextMenu {
                                    x: 32px - self.width;
                                    y: 38px;
                                    album-id: AlbumState.id;
                                    fully-cached: AlbumState.album-fully-cached;
                                    is-blocked: AlbumState.is-album-blocked;
                                    is-pinned: AlbumState.pinned;
                                    media-action(k, i, a) => {
                                        root.media-action(k, i, a);
                                    }
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { height: 20px; }
            // The atmosphere/fade blocks above size themselves to this
            // divider (root.atmo-height) so the gradient ends exactly here.
            header-divider := Rectangle {
                height: 1px;
                background: Theme.border-subtle;
            }
            Rectangle { height: 8px; }

            // --- Track list + label/awards sidebar --------------------------
            // No `alignment: start` here: it would defeat the track list's
            // horizontal-stretch and leave the sidebar floating mid-row
            // with dead space to its right. The track list stretches and
            // the 214px sidebar is pushed flush to the right edge; when a
            // main right sidebar opens, the whole content region narrows
            // and the sidebar rides along with it.
            HorizontalLayout {
                spacing: 32px;

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 0px;
                    alignment: start;

                    if AlbumState.loading && AlbumState.tracks.length == 0: Rectangle {
                        height: 280px;
                        VerticalLayout {
                            alignment: center;
                            spacing: 18px;
                            HorizontalLayout {
                                alignment: center;
                                LoadingSpinner { size: 36px; }
                            }
                            Text {
                                text: @tr("Loading album…");
                                color: Theme.text-muted;
                                font-size: 13px;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    // Toolbar — album quality badge and track search.
                    HorizontalLayout {
                        height: 52px;
                        spacing: 16px;
                        VerticalLayout {
                            alignment: center;
                            QualityBadgeFull {
                                tier: AlbumState.quality-tier;
                                detail: AlbumState.quality-detail;
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                // 60% of the previous 280px so the toolbar gives
                                // room to the square select button beside it.
                                width: 168px;
                                height: 34px;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                background: Theme.surface-elevated;
                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 7px;
                                    VerticalLayout {
                                        alignment: center;
                                        QbzIcon {
                                            source: @image-url("../assets/icons/search.svg");
                                            width: 14px;
                                            height: 14px;
                                            tint: Theme.text-muted;
                                        }
                                    }
                                    // Functional client-side filter.
                                    Rectangle {
                                        horizontal-stretch: 1;
                                        track-search := TextInput {
                                            width: 100%;
                                            height: 100%;
                                            color: Theme.text-primary;
                                            font-size: 13px;
                                            vertical-alignment: center;
                                            single-line: true;
                                            changed has-focus => { UiFocusState.text-input-focused = self.has-focus; }
                                            edited => {
                                                AlbumActions.search(self.text);
                                            }
                                        }
                                        Text {
                                            visible: track-search.text == "";
                                            text: @tr("Search tracks...");
                                            // Span the box so the placeholder
                                            // centers like the TextInput text.
                                            width: 100%;
                                            height: 100%;
                                            color: Theme.text-muted;
                                            font-size: 13px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                        // Multi-select toggle — square (matches the search box,
                        // not the round CircleActions), slightly smaller. Active
                        // (accent) while select mode is on; toggles it.
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 30px;
                                height: 30px;
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: AlbumState.multi-select
                                    ? Theme.accent
                                    : Theme.border-subtle;
                                background: (AlbumState.multi-select || select-ta.has-hover)
                                    ? Theme.surface-hover
                                    : Theme.surface-elevated;
                                QbzIcon {
                                    source: @image-url("../assets/icons/square-check-big.svg");
                                    width: 15px;
                                    height: 15px;
                                    x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                                    y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                                    tint: AlbumState.multi-select
                                        ? Theme.accent
                                        : (select-ta.has-hover
                                            ? Theme.text-primary
                                            : Theme.text-secondary);
                                }
                                select-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        AlbumActions.toggle-multi-select();
                                    }
                                }
                            }
                        }
                    }

                    // Bulk action bar — visible in multi-select mode, over the
                    // selected catalog rows.
                    if AlbumState.multi-select: MultiSelectBar {
                        selected-count: AlbumState.selected-count;
                        actions: [
                            { id: "select-all", label: @tr("Select all"), icon: @image-url("../assets/icons/square-check-big.svg"), danger: false, needs-selection: false },
                            { id: "play-next", label: @tr("Play next"), icon: @image-url("../assets/icons/list-plus.svg"), danger: false, needs-selection: true },
                            { id: "queue", label: @tr("Add to queue"), icon: @image-url("../assets/icons/list-end.svg"), danger: false, needs-selection: true },
                            { id: "add-to-playlist", label: @tr("Add to playlist"), icon: @image-url("../assets/icons/list-music.svg"), danger: false, needs-selection: true },
                            { id: "add-to-favorites", label: @tr("Add to Library"), icon: @image-url("../assets/icons/heart.svg"), danger: false, needs-selection: true },
                            { id: "make-offline", label: @tr("Make available offline"), icon: @image-url("../assets/icons/cloud-download.svg"), danger: false, needs-selection: true },
                            { id: "clear", label: @tr("Clear"), icon: @image-url("../assets/icons/x.svg"), danger: false, needs-selection: true },
                        ];
                        action(id) => {
                            AlbumActions.bulk-action(id);
                        }
                    }
                    if AlbumState.multi-select: Rectangle { height: 8px; }

                    // Column header.
                    HorizontalLayout {
                        height: 40px;
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 16px;
                        Text {
                            text: "#";
                            width: 32px;
                            color: Theme.text-muted;
                            font-size: Typography.legal;
                            letter-spacing: 0.5px;
                            vertical-alignment: center;
                        }
                        Text {
                            // Capital-case to match PlaylistView's column headers.
                            text: @tr("Title");
                            horizontal-stretch: 1;
                            color: Theme.text-muted;
                            font-size: Typography.legal;
                            letter-spacing: 0.5px;
                            vertical-alignment: center;
                        }
                        Text {
                            // Capital-case to match PlaylistView's column headers.
                            text: @tr("Duration");
                            width: 80px;
                            color: Theme.text-muted;
                            font-size: Typography.legal;
                            letter-spacing: 0.5px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        Text {
                            // Capital-case to match PlaylistView's column headers.
                            text: @tr("Quality");
                            width: 80px;
                            color: Theme.text-muted;
                            font-size: Typography.legal;
                            letter-spacing: 0.5px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        // Favorite / offline-cache column headers (Qobuz). For
                        // a local album the rows show a source indicator
                        // instead, so one unlabeled column keeps alignment.
                        if !AlbumState.is-local: Rectangle {
                            width: 28px;
                            QbzIcon {
                                source: @image-url("../assets/icons/heart.svg");
                                width: 14px;
                                height: 14px;
                                x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                                y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                                tint: Theme.text-muted;
                            }
                        }
                        if !AlbumState.is-local: Rectangle {
                            width: 28px;
                            QbzIcon {
                                source: @image-url("../assets/icons/cloud-download.svg");
                                width: 14px;
                                height: 14px;
                                x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                                y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                                tint: Theme.text-muted;
                            }
                        }
                        if AlbumState.is-local: Rectangle { width: 28px; }
                        // Aligns with the per-row more-button slot.
                        Rectangle { width: 32px; }
                    }

                    // Each iteration is a thin column wrapper so a "Disc N"
                    // divider can precede the row when the model marks it as
                    // the first track of a disc (multi-disc albums only; on a
                    // single-disc album disc-header-number is always 0, so the
                    // header `if` never renders and the list stays flat —
                    // unchanged from before). Mirrors the Tauri
                    // PurchaseAlbumDetailView groupByDisc + isMultiDisc markup.
                    for track[index] in AlbumState.tracks: VerticalLayout {
                        spacing: 0px;
                        if track.disc-header-number > 0: Rectangle {
                            height: 40px;
                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 16px;
                                Text {
                                    text: @tr("Disc") + " \{track.disc-header-number}";
                                    color: Theme.text-muted;
                                    font-size: Typography.legal;
                                    font-weight: 600;
                                    letter-spacing: 0.5px;
                                    vertical-alignment: center;
                                    horizontal-alignment: left;
                                    horizontal-stretch: 1;
                                }
                                // Per-disc ⋯ menu — actions scoped to this
                                // disc's tracks only (the column header reserves
                                // a 32px more-button slot on the right; this
                                // aligns with it).
                                VerticalLayout {
                                    alignment: center;
                                    DiscHeaderMenu {
                                        disc: track.disc-header-number;
                                        disc-action(d, a) => {
                                            AlbumActions.disc-action(d, a);
                                        }
                                    }
                                }
                            }
                        }
                        // Classical "work" section header — rendered above the
                        // first row of each consecutive same-work run on albums
                        // that carry work metadata (PR #536, mirroring the
                        // official Qobuz player). Sits BELOW the disc header so
                        // a box set reads disc → work → tracks. Non-classical
                        // albums leave work-header "" and this never renders, so
                        // the list stays flat — unchanged from before.
                        if track.work-header != "": Rectangle {
                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                padding-top: 14px;
                                padding-bottom: 4px;
                                alignment: start;
                                Text {
                                    text: track.work-header;
                                    color: Theme.text-primary;
                                    font-size: Typography.body;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                // " (Composer)" — the composer name links to its
                                // artist page (E3). Hidden when the work carries
                                // no composer.
                                if track.work-composer-name != "": Text {
                                    text: " (";
                                    color: Theme.text-secondary;
                                    font-size: Typography.body;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                if track.work-composer-name != "": composer-ta := TouchArea {
                                    width: composer-text.preferred-width;
                                    height: composer-text.preferred-height;
                                    mouse-cursor: track.work-composer-id != "" ? pointer : default;
                                    enabled: track.work-composer-id != "";
                                    clicked => {
                                        root.media-action("artist", track.work-composer-id, "open");
                                    }
                                    composer-text := Text {
                                        text: track.work-composer-name;
                                        color: composer-ta.has-hover && track.work-composer-id != ""
                                            ? Theme.text-primary
                                            : Theme.text-secondary;
                                        font-size: Typography.body;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }
                                if track.work-composer-name != "": Text {
                                    text: ")";
                                    color: Theme.text-secondary;
                                    font-size: Typography.body;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        TrackRow {
                            track: track;
                            index: index;
                            // Number cell (no cover). Qobuz albums carry the
                            // favorite heart (matching the column header) + the
                            // offline-cache button; local albums show the source
                            // indicator instead.
                            show-artwork: false;
                            show-favorite: !AlbumState.is-local;
                            show-download: !AlbumState.is-local;
                            show-source: AlbumState.is-local;
                            multi-select-mode: AlbumState.multi-select;
                            media-action(kind, id, action) => {
                                root.media-action(kind, id, action);
                            }
                        }
                    }
                }

                // Label / awards sidebar. Collapses to a slim ICON RAIL (56px)
                // when the content area is space-constrained (window <1366 AND
                // a right panel open), so the tracks — what matters in a music
                // app — keep priority. In the rail, only the LABEL/AWARDS
                // headings + the avatars show; names move to hover tooltips.
                if AlbumState.label != "" || AlbumState.awards.length > 0 || AlbumState.show-external-links: VerticalLayout {
                    // 200px: wide enough for the LABEL/AWARDS/EXTERNAL LINKS
                    // cards to breathe; collapses to a 56px icon rail when the
                    // content area is space-constrained so the tracks keep room.
                    width: ShellState.content-constrained ? 56px : 200px;
                    spacing: 24px;
                    alignment: start;

                    if AlbumState.label != "": VerticalLayout {
                        spacing: 8px;
                        SidebarHeading {
                            text: @tr("LABEL");
                            // Centered over the avatar when collapsed to the
                            // icon rail; left-aligned in the full column.
                            horizontal-alignment: ShellState.content-constrained ? center : left;
                        }
                        SidebarCard {
                            icon: @image-url("../assets/icons/disc.svg");
                            name: AlbumState.label;
                            compact: ShellState.content-constrained;
                            avatar-bg: @linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
                            clicked => {
                                if (AlbumState.label-id != "") {
                                    root.media-action("label", AlbumState.label-id, "open");
                                }
                            }
                        }
                    }

                    if AlbumState.awards.length > 0: VerticalLayout {
                        spacing: 8px;
                        SidebarHeading {
                            text: @tr("AWARDS");
                            horizontal-alignment: ShellState.content-constrained ? center : left;
                        }
                        for award in AlbumState.awards: SidebarCard {
                            icon: @image-url("../assets/laurels.svg");
                            name: award.name;
                            compact: ShellState.content-constrained;
                            avatar-bg: @linear-gradient(135deg, #b45309 0%, #eab308 100%);
                            // Navigate to the award page. With an id, open it
                            // directly; without one (Qobuz omits it on some
                            // /album/get entries) pass the NAME and let the
                            // controller resolve it (or toast if unresolved).
                            clicked => {
                                if (award.id != "") {
                                    root.media-action("award", award.id, "open");
                                } else if (award.name != "") {
                                    root.media-action("award", award.name, "resolve-open");
                                }
                            }
                        }
                    }

                    // External links (Last.fm / Discogs / MusicBrainz),
                    // Feishin-style: bare brand SVG icons (native colors), no
                    // visible label — names in hover tooltips. A row in the full
                    // column; stacked + centered in the collapsed icon rail.
                    if AlbumState.show-external-links: VerticalLayout {
                        spacing: 8px;
                        SidebarHeading {
                            text: @tr("EXTERNAL LINKS");
                            horizontal-alignment: ShellState.content-constrained ? center : left;
                        }
                        if !ShellState.content-constrained: HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            if AlbumState.lastfm-url != "": BrandLink {
                                icon: @image-url("../assets/icons/brand-lastfm.svg");
                                name: "Last.fm";
                                clicked => { AlbumActions.open-external-link(AlbumState.lastfm-url); }
                            }
                            if AlbumState.discogs-url != "": BrandLink {
                                icon: @image-url("../assets/icons/brand-discogs.svg");
                                name: "Discogs";
                                clicked => { AlbumActions.open-external-link(AlbumState.discogs-url); }
                            }
                            if AlbumState.musicbrainz-url != "": BrandLink {
                                icon: @image-url("../assets/icons/brand-musicbrainz.svg");
                                name: "MusicBrainz";
                                clicked => { AlbumActions.open-external-link(AlbumState.musicbrainz-url); }
                            }
                        }
                        if ShellState.content-constrained: VerticalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                alignment: center;
                                if AlbumState.lastfm-url != "": BrandLink {
                                    icon: @image-url("../assets/icons/brand-lastfm.svg");
                                    name: "Last.fm";
                                    clicked => { AlbumActions.open-external-link(AlbumState.lastfm-url); }
                                }
                            }
                            HorizontalLayout {
                                alignment: center;
                                if AlbumState.discogs-url != "": BrandLink {
                                    icon: @image-url("../assets/icons/brand-discogs.svg");
                                    name: "Discogs";
                                    clicked => { AlbumActions.open-external-link(AlbumState.discogs-url); }
                                }
                            }
                            HorizontalLayout {
                                alignment: center;
                                if AlbumState.musicbrainz-url != "": BrandLink {
                                    icon: @image-url("../assets/icons/brand-musicbrainz.svg");
                                    name: "MusicBrainz";
                                    clicked => { AlbumActions.open-external-link(AlbumState.musicbrainz-url); }
                                }
                            }
                        }
                    }
                }
            }

            // --- Bottom carousels (1:1 with the Qobuz webplayer) -------------
            // "More from <artist>" with a View-all link to the artist's
            // releases, then "Suggestions" — both full-width below the track
            // list / sidebar row. Gated independently by the Rust controller.
            if AlbumState.show-more-from-artist: Rectangle { height: 40px; }
            if AlbumState.show-more-from-artist: Carousel {
                section: AlbumState.more-from-artist;
                show-view-all: true;
                album-clicked(id) => {
                    root.media-action("album", id, "open");
                }
                view-all-clicked => {
                    root.media-action("artist", AlbumState.artist-id, "releases");
                }
                media-action(k, i, a) => {
                    root.media-action(k, i, a);
                }
            }

            if AlbumState.show-suggestions: Rectangle { height: 40px; }
            if AlbumState.show-suggestions: Carousel {
                section: AlbumState.suggestions-section;
                show-view-all: false;
                album-clicked(id) => {
                    root.media-action("album", id, "open");
                }
                media-action(k, i, a) => {
                    root.media-action(k, i, a);
                }
            }

            // Second suggestions row, from Last.fm similar artists (one album
            // each), deduped against the Qobuz row above. Grouped UNDER the same
            // "Suggestions" heading (the carousel carries an empty title, no
            // sub-label). Hidden unless Last.fm is connected and the row
            // resolved at least one album.
            if AlbumState.show-lastfm-suggestions: Rectangle { height: 14px; }
            if AlbumState.show-lastfm-suggestions: Carousel {
                section: AlbumState.lastfm-suggestions-section;
                show-view-all: false;
                album-clicked(id) => {
                    root.media-action("album", id, "open");
                }
                media-action(k, i, a) => {
                    root.media-action(k, i, a);
                }
            }
        }
    }

    // Shared scrollbar in the right gutter (homologated cross-view).
    ListScrollbar {
        x: parent.width - self.width - 4px;
        width: 14px;
        height: 100%;
        viewport-height: flick.viewport-height;
        visible-height: flick.height;
        viewport-y <=> flick.viewport-y;
    }

    // --- Full-description modal --------------------------------------------
    if root.show-description: Rectangle {
        background: #000000bf;

        // Scrim — a click anywhere outside the panel dismisses.
        TouchArea {
            mouse-cursor: default;
            clicked => {
                root.show-description = false;
            }
        }

        Rectangle {
            width: Math.min(root.width - 80px, 560px);
            height: Math.min(root.height - 120px, 460px);
            x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
            y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
            border-radius: Radius.md;
            background: Theme.surface-card;
            border-width: 1px;
            border-color: Theme.border-subtle;
            drop-shadow-blur: 32px;
            drop-shadow-color: Theme.card-shadow;

            // Swallow clicks so they do not reach the scrim.
            TouchArea { }

            VerticalLayout {
                padding: 24px;
                spacing: 14px;

                HorizontalLayout {
                    Text {
                        text: @tr("About this album");
                        color: Theme.text-primary;
                        font-size: Typography.heading;
                        font-weight: Typography.semibold;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    close-x := TouchArea {
                        width: 28px;
                        height: 28px;
                        mouse-cursor: pointer;
                        clicked => {
                            root.show-description = false;
                        }
                        QbzIcon {
                            source: @image-url("../assets/icons/x.svg");
                            width: 18px;
                            height: 18px;
                            x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                            y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                            tint: close-x.has-hover ? Theme.text-primary : Theme.text-muted;
                        }
                    }
                }

                // vertical-stretch bounds the Flickable to the leftover
                // panel height so a long description actually scrolls.
                Flickable {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    viewport-height: desc-text.preferred-height;
                    desc-text := Text {
                        width: parent.width;
                        text: AlbumState.description;
                        color: Theme.text-secondary;
                        font-size: Typography.body;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
