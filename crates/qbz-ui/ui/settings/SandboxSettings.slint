// Settings > Sandbox — the one-time permission commands for sandboxed
// installs (Tauri parity: the old Settings > Flatpak / Snap sections).
// Shown only when the app runs inside Flatpak or Snap (SandboxState.
// install-method); hidden on native/dev installs.
//
// Flatpak rows: exclusive-DAC D-Bus reservation (the user-side fix for
// discussion #641 — the Flathub manifest can't carry the wildcard own-name,
// so the user grants it locally via `flatpak override`), direct sound-device
// access (the user-side fix for #652 — without /dev/snd inside the sandbox
// an ALSA "exclusive" output can't open hw:X,0 and silently falls back to
// PipeWire; the owner decided against a manifest change to avoid Flathub
// reviewer friction) and filesystem access for NAS/external music
// libraries. Discord's IPC override stays in
// Integrations (already there). Snap rows: the audio interface connections
// from the Tauri section (snap name is `qbz-player`).
//
// Commands are plain strings (never translated); surrounding copy goes
// through @tr. Copy feedback is local UI state (Copied! for 1.5 s); the
// clipboard write itself is SandboxState.copy-command → share::copy_to_clipboard.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { SandboxState } from "../state.slint";

component GroupHeader inherits Text {
    color: Theme.text-muted;
    font-size: 11px;
    letter-spacing: 1.5px;
    font-weight: Typography.semibold;
}

component RowTitle inherits Text {
    color: Theme.text-primary;
    font-size: Typography.body;
    font-weight: Typography.medium;
    wrap: word-wrap;
}

component RowNote inherits Text {
    color: Theme.text-muted;
    font-size: Typography.legal;
    wrap: word-wrap;
}

// Matches AudioSettings/OfflineSettings' SecondaryButton.
component SecondaryButton inherits Rectangle {
    in property <string> label;
    callback clicked();
    // 160px floor keeps the settings right-edge grid; longer translations grow.
    width: Math.max(label-txt.preferred-width + 32px, 160px);
    height: 34px;
    border-radius: Radius.sm;
    border-width: 1px;
    border-color: Theme.border-subtle;
    background: ta.has-hover ? Theme.surface-hover : Theme.surface-elevated;
    label-txt := Text {
        width: 100%;
        height: 100%;
        text: root.label;
        color: Theme.text-secondary;
        font-size: Typography.body;
        font-weight: Typography.medium;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

// Full-width shell-command row with copy-to-clipboard feedback. `command`
// may hold several lines; the whole block copies as one clipboard payload.
component CommandBlock inherits Rectangle {
    in property <string> command;
    property <bool> copied: false;

    border-radius: Radius.sm;
    border-width: 1px;
    border-color: Theme.border-subtle;
    background: Theme.surface-elevated;
    height: cmd-layout.preferred-height;

    cmd-layout := HorizontalLayout {
        padding: 10px;
        spacing: 12px;
        Text {
            text: root.command;
            color: Theme.text-primary;
            font-family: "monospace";
            font-size: Typography.legal;
            wrap: word-wrap;
            horizontal-stretch: 1;
            vertical-alignment: center;
        }
        VerticalLayout {
            alignment: center;
            SecondaryButton {
                label: root.copied ? @tr("Copied!") : @tr("Copy");
                clicked => {
                    SandboxState.copy-command(root.command);
                    root.copied = true;
                    copied-timer.restart();
                }
            }
        }
    }
    copied-timer := Timer {
        running: false;
        interval: 1500ms;
        triggered => {
            root.copied = false;
            copied-timer.stop();
        }
    }
}

export component SandboxSettings inherits VerticalLayout {
    spacing: 4px;
    alignment: start;

    // --- FLATPAK ---------------------------------------------------------
    if SandboxState.install-method == "flatpak": VerticalLayout {
        spacing: 4px;
        alignment: start;

        GroupHeader { text: @tr("FLATPAK SANDBOX"); }
        RowNote {
            text: @tr("QBZ is running inside a Flatpak sandbox. Some features need one-time permission grants — run the commands in a terminal, then restart QBZ. Grants persist across updates.");
        }
        Rectangle { height: 8px; }

        RowTitle { text: @tr("Exclusive DAC access (bit-perfect)"); }
        RowNote {
            text: @tr("Recommended for exclusive mode: lets QBZ ask PipeWire to hand over the DAC cleanly (D-Bus device reservation).");
        }
        CommandBlock {
            command: "flatpak override --user --own-name=org.freedesktop.ReserveDevice1.* com.blitzfc.qbz";
        }
        Rectangle { height: 8px; }

        RowTitle { text: @tr("ALSA direct / exclusive DAC access"); }
        RowNote {
            text: @tr("Exclusive mode silently falls back to PipeWire without this grant: the sandbox cannot see the sound hardware (/dev/snd), so even with ALSA + hw + Exclusive selected other apps still mix through the DAC. Grants direct device access; restart QBZ afterwards.");
        }
        CommandBlock {
            command: "flatpak override --user --device=all com.blitzfc.qbz";
        }
        Rectangle { height: 8px; }

        RowTitle { text: @tr("Music on NAS or external drives"); }
        RowNote {
            text: @tr("Grants access to a folder outside the sandbox. Repeat the command for each folder you need.");
        }
        CommandBlock {
            command: "flatpak override --user --filesystem=/path/to/your/music com.blitzfc.qbz";
        }
    }

    // --- SNAP ------------------------------------------------------------
    if SandboxState.install-method == "snap": VerticalLayout {
        spacing: 4px;
        alignment: start;

        GroupHeader { text: @tr("SNAP SANDBOX"); }
        RowNote {
            text: @tr("QBZ is running inside a Snap sandbox. Some audio interfaces need one-time connections — run these commands in a terminal, then restart QBZ.");
        }
        Rectangle { height: 8px; }

        RowTitle { text: @tr("Required audio connections"); }
        CommandBlock {
            command: "sudo snap connect qbz-player:alsa\nsudo snap connect qbz-player:pulseaudio\nsudo snap connect qbz-player:pipewire\nsudo snap connect qbz-player:mpris";
        }
        Rectangle { height: 8px; }

        RowTitle { text: @tr("Optional — external drives & NAS"); }
        CommandBlock {
            command: "sudo snap connect qbz-player:removable-media";
        }
    }
}
