// Settings > Developer — opt-in home for developer/diagnostic tools. Same
// structure as the other settings panels (GroupHeader + SettingRow + a
// SecondaryButton). Currently launches the Qobuz Connect diagnostics modal
// (live session topology + rolling event log); more dev tools can land here.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { QconnectDevState, LogViewerState } from "../state.slint";
import { SettingRow } from "SettingRow.slint";
import { DiagnosticsPanel } from "DiagnosticsPanel.slint";

component GroupHeader inherits Text {
    color: Theme.text-muted;
    font-size: 11px;
    letter-spacing: 1.5px;
    font-weight: Typography.semibold;
}

component SecondaryButton inherits Rectangle {
    in property <string> label;
    callback clicked();
    // 160px floor keeps the settings right-edge grid; longer translations grow.
    width: Math.max(label-txt.preferred-width + 32px, 160px);
    height: 34px;
    border-radius: Radius.sm;
    border-width: 1px;
    border-color: Theme.border-subtle;
    background: ta.has-hover ? Theme.surface-hover : Theme.surface-elevated;
    label-txt := Text {
        width: 100%;
        height: 100%;
        text: root.label;
        color: Theme.text-secondary;
        font-size: Typography.body;
        font-weight: Typography.medium;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component DeveloperSettings inherits VerticalLayout {
    spacing: 4px;

    GroupHeader { text: @tr("QOBUZ CONNECT"); }

    SettingRow {
        label: @tr("Connect diagnostics");
        description: @tr("Live session topology and a rolling event log for debugging Qobuz Connect at runtime.");
        SecondaryButton {
            label: @tr("Open diagnostics");
            clicked => {
                QconnectDevState.open = true;
            }
        }
    }

    GroupHeader { text: @tr("LOGS"); }

    SettingRow {
        label: @tr("Application logs");
        description: @tr("View the in-app log, copy it (secrets redacted), or upload it to share in a GitHub issue.");
        SecondaryButton {
            label: @tr("Open log viewer");
            clicked => {
                LogViewerState.open = true;
            }
        }
    }

    DiagnosticsPanel { }
}
