// Settings > Blacklist (content filtering) — a single row that mirrors the
// Tauri SettingsView content-filtering section (SettingsView.svelte:5945-5969):
//
//  - a blind-eye icon (Tauri's lucide `Ban`; the Slint build has no Ban asset,
//    so it reuses the same blind-eye stand-in the Manager uses),
//  - the "Artist Blacklist" label,
//  - a status line "{count} artist(s) blocked" with a trailing "(disabled)"
//    suffix when the feature is off,
//  - a "Manage" affordance (chevron) that opens the Blacklist Manager view via
//    the global BlacklistActions.open() seam (the same forward-open the manager
//    back-chrome pairs with).
//
// There is NO enable/disable toggle here (Tauri parity): the global on/off
// switch lives inside the Manager. The count + enabled flag are seeded onto
// BlacklistState whenever the Settings view is shown (main.rs
// seed_blacklist_status), and the Manager re-seeds them on its own load.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { BlacklistState, BlacklistActions } from "../state.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";

// "Manage" affordance — same 160x34 / right-edge style as the other settings
// panels' SecondaryButton, but with a trailing chevron (Tauri's Manage link).
component ManageButton inherits Rectangle {
    callback clicked();
    // 160px floor keeps the settings right-edge grid; longer translations grow.
    width: Math.max(content-l.preferred-width + 32px, 160px);
    height: 34px;
    border-radius: Radius.sm;
    border-width: 1px;
    border-color: Theme.border-subtle;
    background: ta.has-hover ? Theme.surface-hover : Theme.surface-elevated;
    content-l := HorizontalLayout {
        alignment: center;
        spacing: 6px;
        VerticalLayout {
            alignment: center;
            Text {
                text: @tr("Manage");
                color: Theme.text-secondary;
                font-size: Typography.body;
                font-weight: Typography.medium;
                vertical-alignment: center;
            }
        }
        VerticalLayout {
            alignment: center;
            QbzIcon {
                source: @image-url("../assets/icons/chevron-right.svg");
                width: 16px;
                height: 16px;
                tint: Theme.text-secondary;
            }
        }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component ContentFilteringSettings inherits VerticalLayout {
    spacing: 4px;

    HorizontalLayout {
        height: 64px;
        spacing: 24px;

        // Icon + label + status line (left).
        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 12px;
            VerticalLayout {
                alignment: center;
                QbzIcon {
                    source: @image-url("../assets/icons/blind-eye.svg");
                    width: 18px;
                    height: 18px;
                    tint: Theme.text-secondary;
                }
            }
            VerticalLayout {
                alignment: center;
                spacing: 3px;
                Text {
                    text: @tr("Blacklist");
                    color: Theme.text-primary;
                    font-size: Typography.body;
                    font-weight: Typography.medium;
                }
                Text {
                    // "{n} artists, {m} albums blocked" + "(disabled)" when off.
                    text: BlacklistState.enabled
                        ? @tr("{} artists, {} albums blocked", BlacklistState.count, BlacklistState.album-count)
                        : @tr("{} artists, {} albums blocked (disabled)", BlacklistState.count, BlacklistState.album-count);
                    color: Theme.text-muted;
                    font-size: 12px;
                }
            }
        }

        // Manage affordance (right).
        VerticalLayout {
            alignment: center;
            ManageButton {
                clicked => {
                    BlacklistActions.open();
                }
            }
        }
    }
}
